#!/bin/bash

# ESTADO SGI360 - Sistema de Gestión Integral
# Script para verificar el estado del sistema

echo "🔍 Verificando estado de SGI360 - Sistema de Gestión Integral..."

# Colores para output
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Directorio del proyecto
PROJECT_DIR="/Users/leonardocastillo/Desktop/APP/SGI 360"

echo ""
echo -e "${BLUE}📋 Estado de los Servicios:${NC}"
echo ""

# Función para verificar puerto
check_port() {
    local port=$1
    local service=$2
    local url=$3
    
    if lsof -Pi :$port -sTCP:LISTEN -t >/dev/null 2>&1; then
        echo -e "${GREEN}✅ $service (puerto $port) - ACTIVO${NC}"
        
        # Verificar si responde
        if curl -s --max-time 2 "$url" >/dev/null 2>&1; then
            echo -e "   🌐 Respondiendo en: $url"
        else
            echo -e "   ⚠️  No responde (iniciando...)"
        fi
    else
        echo -e "${RED}❌ $service (puerto $port) - INACTIVO${NC}"
    fi
}

# Verificar Backend API
check_port 3001 "Backend API" "http://localhost:3001/health"

# Verificar Frontend Web
check_port 3000 "Frontend Web" "http://localhost:3000"

echo ""
echo -e "${BLUE}📁 Archivos de Logs:${NC}"
echo ""

# Verificar logs
API_DIR="$PROJECT_DIR/apps/api"
WEB_DIR="$PROJECT_DIR/apps/web"

if [ -f "$API_DIR/api.log" ]; then
    echo -e "🔧 API Log: $API_DIR/api.log"
    echo -e "   Últimas líneas:"
    tail -3 "$API_DIR/api.log" 2>/dev/null | sed 's/^/   /'
else
    echo -e "${YELLOW}⚠️  API Log no encontrado${NC}"
fi

echo ""

if [ -f "$WEB_DIR/web.log" ]; then
    echo -e "🌐 Web Log: $WEB_DIR/web.log"
    echo -e "   Últimas líneas:"
    tail -3 "$WEB_DIR/web.log" 2>/dev/null | sed 's/^/   /'
else
    echo -e "${YELLOW}⚠️  Web Log no encontrado${NC}"
fi

echo ""
echo -e "${BLUE}📂 Archivos del Sistema:${NC}"
echo ""

# Verificar archivos PID
if [ -f "$PROJECT_DIR/.api_pid" ]; then
    API_PID=$(cat "$PROJECT_DIR/.api_pid")
    echo -e "🔧 API PID: $API_PID (archivo: .api_pid)"
else
    echo -e "${YELLOW}⚠️  Archivo .api_pid no encontrado${NC}"
fi

if [ -f "$PROJECT_DIR/.web_pid" ]; then
    WEB_PID=$(cat "$PROJECT_DIR/.web_pid")
    echo -e "🌐 Web PID: $WEB_PID (archivo: .web_pid)"
else
    echo -e "${YELLOW}⚠️  Archivo .web_pid no encontrado${NC}"
fi

echo ""
echo -e "${BLUE}📚 Documentos en el Sistema:${NC}"
echo ""

# Verificar documentos
if [ -d "$API_DIR/uploads/documents" ]; then
    DOC_COUNT=$(find "$API_DIR/uploads/documents" -maxdepth 1 -type f ! -name '*-v*' | wc -l)
    VER_COUNT=$(find "$API_DIR/uploads/documents" -maxdepth 1 -type f -name '*-v*' | wc -l)
    echo -e "📄 Documentos principales: $DOC_COUNT"
    echo -e "📝 Versiones: $VER_COUNT"
else
    echo -e "${RED}❌ Directorio de documentos no encontrado${NC}"
fi

echo ""
echo -e "${BLUE}🎯 Accesos Rápidos:${NC}"
echo -e "   📱 Documentos: http://localhost:3000/documents"
echo -e "   🔧 API Health: http://localhost:3001/health"
echo -e "   🌐 Frontend:   http://localhost:3000"
echo ""

echo -e "${GREEN}✨ Verificación completada! ✨${NC}"
