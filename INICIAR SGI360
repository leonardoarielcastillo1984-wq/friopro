#!/bin/bash

# INICIAR SGI360 - Sistema de Gestión Integral
# Script para iniciar el backend, frontend y abrir el navegador automáticamente

echo "🚀 Iniciando SGI360 - Sistema de Gestión Integral..."

# Colores para output
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Directorio del proyecto
PROJECT_DIR="/Users/leonardocastillo/Desktop/APP/SGI 360"
API_DIR="$PROJECT_DIR/apps/api"
WEB_DIR="$PROJECT_DIR/apps/web"

echo -e "${BLUE}📂 Directorio del proyecto: $PROJECT_DIR${NC}"

# Función para verificar si un puerto está en uso
check_port() {
    local port=$1
    if lsof -Pi :$port -sTCP:LISTEN -t >/dev/null 2>&1; then
        return 0  # Puerto en uso
    else
        return 1  # Puerto libre
    fi
}

# Función para detener procesos en puertos específicos
stop_port() {
    local port=$1
    echo -e "${YELLOW}🔄 Deteniendo procesos en puerto $port...${NC}"
    lsof -ti:$port | xargs kill -9 2>/dev/null || true
}

# Detener procesos existentes si están corriendo
echo -e "${YELLOW}🔄 Limpiando procesos anteriores...${NC}"
stop_port 3001  # API
stop_port 3000  # Frontend

# Esperar un momento para que los puertos se liberen
sleep 2

# Iniciar Backend API
echo -e "${BLUE}🔧 Iniciando Backend API (puerto 3001)...${NC}"
cd "$API_DIR"
nohup npx tsx simple-server.ts > api.log 2>&1 &
API_PID=$!

# Esperar a que la API esté lista
echo -e "${YELLOW}⏳ Esperando a que la API esté lista...${NC}"
for i in {1..30}; do
    if curl -s http://localhost:3001/health >/dev/null 2>&1; then
        echo -e "${GREEN}✅ API Backend está lista!${NC}"
        break
    fi
    if [ $i -eq 30 ]; then
        echo -e "${YELLOW}⚠️  La API tardó más de lo esperado, pero continuando...${NC}"
        break
    fi
    sleep 1
done

# Iniciar Frontend Web
echo -e "${BLUE}🌐 Iniciando Frontend Web (puerto 3000)...${NC}"
cd "$WEB_DIR"
nohup pnpm dev > web.log 2>&1 &
WEB_PID=$!

# Esperar a que el frontend esté listo
echo -e "${YELLOW}⏳ Esperando a que el Frontend esté listo...${NC}"
for i in {1..60}; do
    if curl -s http://localhost:3000 >/dev/null 2>&1; then
        echo -e "${GREEN}✅ Frontend Web está listo!${NC}"
        break
    fi
    if [ $i -eq 60 ]; then
        echo -e "${YELLOW}⚠️  El Frontend tardó más de lo esperado, pero continuando...${NC}"
        break
    fi
    sleep 1
done

# Abrir el navegador
echo -e "${BLUE}🌍 Abriendo el navegador...${NC}"
sleep 2
open http://localhost:3000/documents

# Mostrar información del sistema
echo ""
echo -e "${GREEN}🎉 SGI360 está completamente operativo!${NC}"
echo ""
echo -e "${BLUE}📋 Información del Sistema:${NC}"
echo -e "   📱 Frontend:  http://localhost:3000"
echo -e "   🔧 Backend:   http://localhost:3001"
echo -e "   📚 Documentos: http://localhost:3000/documents"
echo -e "   💾 API Health: http://localhost:3001/health"
echo ""
echo -e "${BLUE}📝 Logs del Sistema:${NC}"
echo -e "   🔧 API Log:   $API_DIR/api.log"
echo -e "   🌐 Web Log:   $WEB_DIR/web.log"
echo ""
echo -e "${BLUE}⚡ PIDs de los Procesos:${NC}"
echo -e "   🔧 API PID:    $API_PID"
echo -e "   🌐 Web PID:    $WEB_PID"
echo ""
echo -e "${GREEN}🎯 Para detener el sistema:${NC}"
echo -e "   kill $API_PID $WEB_PID"
echo -e "   o ejecuta: lsof -ti:3000,3001 | xargs kill -9"
echo ""

# Guardar PIDs en un archivo para fácil detención
echo "$API_PID" > "$PROJECT_DIR/.api_pid"
echo "$WEB_PID" > "$PROJECT_DIR/.web_pid"

echo -e "${GREEN}✨ ¡Listo para usar SGI360! ✨${NC}"
