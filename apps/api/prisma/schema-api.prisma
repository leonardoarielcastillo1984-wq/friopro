  updatedAt     DateTime  @updatedAt @db.Timestamptz

  aspect      EnvironmentalAspect @relation(fields: [aspectId], references: [id], onDelete: Cascade)
  responsible Employee? @relation("EnvironmentalActionAssigned", fields: [responsibleId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([aspectId])
  @@index([status])
  @@map("environmental_actions")
}

model EnvironmentalControl {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  aspectId    String    @db.Uuid
  type        String    // OPERATIONAL, ENGINEERING, ADMINISTRATIVE
  description String
  implemented Boolean   @default(false)
  effective   Boolean   @default(false)
  observation String?
