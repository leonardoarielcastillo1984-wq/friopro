// ═══════════════════════════════════════════════════════════
// Módulo Audit360 — Auditorías ISO (Programas, Auditorías, Hallazgos)
// ═══════════════════════════════════════════════════════════

enum AuditType {
  INTERNAL
  EXTERNAL
  SUPPLIER
  CUSTOMER
  CERTIFICATION
  RECERTIFICATION
  SURVEILLANCE
}

enum AuditStatus {
  DRAFT
  PLANNED
  SCHEDULED
  IN_PROGRESS
  PENDING_REPORT
  COMPLETED
  CLOSED
}

enum AuditResult {
  CONFORME
  PARCIAL
  NO_CONFORME
}

enum AuditFindingType {
  NON_CONFORMITY
  OBSERVATION
  OPPORTUNITY
  POSITIVE_PRACTICE
}

enum AuditFindingSeverity {
  MAJOR
  MINOR
  CRITICAL
  OBSERVATION
  OPPORTUNITY
}

enum AuditFindingStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  CANCELLED
}

enum AuditChecklistResponse {
  COMPLIES
  DOES_NOT_COMPLY
  NOT_APPLICABLE
}

enum AuditorType {
  INTERNAL
  EXTERNAL
}

enum AuditTeamRole {
  LEADER
  AUDITOR
  OBSERVER
}

model AuditProgram {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  year        Int
  name        String
  description String?
  createdById String?  @db.Uuid
  deletedAt   DateTime? @db.Timestamptz
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  audits Audit[]

  @@index([tenantId])
  @@map("audit_programs")
}

model Auditor {
  id                    String   @id @default(uuid()) @db.Uuid
  tenantId              String   @db.Uuid
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type                  AuditorType
  name                  String
  email                 String
  phone                 String?
  company               String?
  employeeId            String?  @db.Uuid
  normativeCompetencies String[]
  isActive              Boolean  @default(true)
  createdById           String?  @db.Uuid
  deletedAt             DateTime? @db.Timestamptz
  createdAt             DateTime @default(now()) @db.Timestamptz
  updatedAt             DateTime @updatedAt @db.Timestamptz

  documents   AuditorDocument[]
  auditTeams  AuditTeam[]

  @@index([tenantId])
  @@map("auditors")
}

model AuditorDocument {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  auditorId   String   @db.Uuid
  auditor     Auditor  @relation(fields: [auditorId], references: [id], onDelete: Cascade)
  title       String
  description String?
  filePath    String
  fileSize    Int?
  mimeType    String   @default("application/pdf")
  issueDate   DateTime? @db.Timestamptz
  expiryDate  DateTime? @db.Timestamptz
  issuer      String?
  deletedAt   DateTime? @db.Timestamptz
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  @@index([tenantId])
  @@index([auditorId])
  @@map("auditor_documents")
}

model Audit {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @db.Uuid
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  programId         String?  @db.Uuid
  program           AuditProgram? @relation(fields: [programId], references: [id], onDelete: SetNull)
  code              String
  title             String
  description       String?
  type              AuditType
  status            AuditStatus @default(DRAFT)
  plannedStartDate  DateTime? @db.Timestamptz
  plannedEndDate    DateTime? @db.Timestamptz
  duration          Int?
  leadAuditorId     String?  @db.Uuid
  area              String
  process           String?
  isoStandard       String[]
  scope             String?
  objective         String?
  interviewees      String?
  result            AuditResult?
  complianceScore   Float?
  createdById       String?  @db.Uuid
  deletedAt         DateTime? @db.Timestamptz
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz

  findings      AuditFinding[]
  checklist     AuditChecklistItem[]
  report        AuditReport?
  team          AuditTeam[]
  schedule      AuditSchedule[]

  @@index([tenantId])
  @@index([status])
  @@unique([tenantId, code])
  @@map("audits")
}

model AuditChecklistItem {
  id            String   @id @default(uuid()) @db.Uuid
  auditId       String   @db.Uuid
  audit         Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  clause        String
  requirement   String
  whatToCheck   String?
  weight        Int      @default(1)
  order         Int      @default(0)
  response      AuditChecklistResponse?
  comment       String?
  evidence      String?
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  @@index([auditId])
  @@map("audit_checklist_items")
}

model AuditFinding {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditId       String   @db.Uuid
  audit         Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  code          String
  type          AuditFindingType @default(NON_CONFORMITY)
  severity      AuditFindingSeverity @default(MINOR)
  status        AuditFindingStatus @default(OPEN)
  description   String
  evidence      String?
  clause        String?
  requirement   String?
  area          String?
  process       String?
  responsibleId String?  @db.Uuid
  ncrId         String?  @db.Uuid
  ncr           NonConformity? @relation(fields: [ncrId], references: [id], onDelete: SetNull)
  detectedAt    DateTime @default(now()) @db.Timestamptz
  closedAt      DateTime? @db.Timestamptz
  createdById   String?  @db.Uuid
  deletedAt     DateTime? @db.Timestamptz
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  actions AuditFindingAction[]

  @@index([tenantId])
  @@index([auditId])
  @@index([status])
  @@map("audit_findings")
}

model AuditFindingAction {
  id            String   @id @default(uuid()) @db.Uuid
  findingId     String   @db.Uuid
  finding       AuditFinding @relation(fields: [findingId], references: [id], onDelete: Cascade)
  description   String
  rootCause     String?
  type          String   @default("CORRECTIVE")
  status        String   @default("PENDING")
  responsibleId String?  @db.Uuid
  plannedDate   DateTime? @db.Timestamptz
  completedDate DateTime? @db.Timestamptz
  evidence      String?
  isEffective   Boolean?
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  @@index([findingId])
  @@map("audit_finding_actions")
}

model AuditReport {
  id                String   @id @default(uuid()) @db.Uuid
  auditId           String   @unique @db.Uuid
  audit             Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  executiveSummary  String?  @db.Text
  objective         String?
  scope             String?
  processesAudited  String[]
  overallScore      Float?
  totalItems        Int?
  compliantItems    Int?
  nonCompliantItems Int?
  totalFindings     Int?
  openFindings      Int?
  closedFindings    Int?
  conclusion        String?  @db.Text
  generatedById     String?  @db.Uuid
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz

  @@map("audit_reports")
}

model AuditTeam {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditId   String   @db.Uuid
  audit     Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  auditorId String?  @db.Uuid
  auditor   Auditor? @relation(fields: [auditorId], references: [id], onDelete: SetNull)
  role      AuditTeamRole @default(AUDITOR)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@unique([auditId, userId])
  @@index([tenantId])
  @@index([auditId])
  @@map("audit_teams")
}

model AuditSchedule {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditId     String   @db.Uuid
  audit       Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  phase       String
  plannedDate DateTime? @db.Timestamptz
  actualDate  DateTime? @db.Timestamptz
  duration    Int?
  location    String?
  notes       String?
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  @@index([tenantId])
  @@index([auditId])
  @@map("audit_schedules")
}
