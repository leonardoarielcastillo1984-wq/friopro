  updatedAt   DateTime  @updatedAt @db.Timestamptz

  aspect EnvironmentalAspect @relation(fields: [aspectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([aspectId])
  @@map("environmental_controls")
}

model EnvironmentalReview {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @db.Uuid
  aspectId     String    @db.Uuid
  reviewDate   DateTime  @db.Timestamptz
  result       String    // CONTROLLED, NOT_CONTROLLED
  comments     String?
  reviewedById String?   @db.Uuid
  createdAt    DateTime  @default(now()) @db.Timestamptz
  updatedAt    DateTime  @updatedAt @db.Timestamptz

  aspect     EnvironmentalAspect @relation(fields: [aspectId], references: [id], onDelete: Cascade)
