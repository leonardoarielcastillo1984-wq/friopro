generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums for NonConformity
enum NCRSeverity {
  CRITICAL
  MAJOR
  MINOR
  OBSERVATION
}

enum NCRSource {
  AUDIT
  INCIDENT
  COMPLAINT
  MONITORING
  SUPPLIER
  OTHER
}

enum NCRStatus {
  OPEN
  IN_PROGRESS
  PENDING_VERIFICATION
  CLOSED
  CANCELLED
}

// Tenant model for SaaS
model Tenant {
  id                String    @id @default(uuid()) @db.Uuid
  name              String
  slug              String    @unique
  adminEmail        String    @unique
  adminName         String
  status            String    @default("ACTIVE")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  sgiObjectives     SgiObjective[]
  policies          Policy[]
  nonConformities   NonConformity[]

  @@index([slug])
  @@index([status])
}

model NonConformity {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code        String
  title       String
  description String

  severity NCRSeverity
  source   NCRSource
  status   NCRStatus @default(OPEN)

  standard       String?
  clause         String?
  rootCause      String?
  analysisMethod String?
  correctiveAction String?
  preventiveAction String?

  detectedAt DateTime @default(now()) @db.Timestamptz
  dueDate    DateTime? @db.Timestamptz
  closedAt   DateTime? @db.Timestamptz

  verificationNotes String?
  verificationDate  DateTime? @db.Timestamptz
  isEffective       Boolean?

  assignedToId String?       @db.Uuid
  assignedTo   PlatformUser? @relation("NcrAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  aiFindingId String? @db.Uuid

  // Proceso asociado para análisis de riesgo
  processId String? @db.Uuid
  process   String? // Nombre del proceso para análisis IA

  // Trazabilidad desde Indicadores (KPI)
  indicatorId            String?               @db.Uuid
  indicator              Indicator?            @relation("NcrIndicator", fields: [indicatorId], references: [id], onDelete: SetNull)
  indicatorMeasurementId String?               @db.Uuid
  indicatorMeasurement   IndicatorMeasurement? @relation("NcrIndicatorMeasurement", fields: [indicatorMeasurementId], references: [id], onDelete: SetNull)

  // Trazabilidad desde Riesgos
  riskId                 String?               @db.Uuid
  risk                   Risk?                 @relation("NcrRisk", fields: [riskId], references: [id], onDelete: SetNull)

  // Trazabilidad desde IPERC (Peligros SST)
  hazardId               String?               @db.Uuid
  hazard                 Hazard?               @relation("NcrHazard", fields: [hazardId], references: [id], onDelete: SetNull)

  // Trazabilidad desde Aspectos Ambientales
  environmentalAspectId   String?               @db.Uuid
  environmentalAspect     EnvironmentalAspect?  @relation("NcrEnvironmentalAspect", fields: [environmentalAspectId], references: [id], onDelete: SetNull)

  // Trazabilidad desde Simulacros
  drillId                 String?               @db.Uuid
  drill                   DrillScenario?        @relation("NcrDrill", fields: [drillId], references: [id], onDelete: SetNull)

  // Trazabilidad desde Clientes
  customerLinks          Customer[]            @relation("CustomerNCR")

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  createdById String?       @db.Uuid
  createdBy   PlatformUser? @relation("NcrCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedById String?       @db.Uuid
  updatedBy   PlatformUser? @relation("NcrUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  deletedAt DateTime? @db.Timestamptz

  isoStandard       String?
  sstImpact         Boolean? @default(false)
  environmentalImpact Boolean? @default(false)
  relatedIds        String?
  aiAnalysis        String?  @db.Text
  aiRecommendation  String?  @db.Text
  aiPriority        String?
  aiSuggestedCapaId String?  @db.Uuid

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([drillId])
}

// Rest of the code remains the same

// Preferencia de pago (para MercadoPago checkout)
model PaymentPreference {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  userId    String?  @db.Uuid
  
  // Plan seleccionado
  planTier  String
  period    String   @default("monthly") // monthly, annual
  amount    Float
  currency  String   @default("USD")
  
  // MercadoPago
  mpPreferenceId String? @unique
  mpInitPoint    String?
  
  // Estado
  status    String   @default("PENDING") // PENDING, COMPLETED, CANCELLED, EXPIRED
  
  // Metadatos del pago
  paymentData    Json?    // Datos del pago cuando se completa
  
  createdAt      DateTime @default(now()) @db.Timestamptz
  updatedAt      DateTime @updatedAt @db.Timestamptz
  expiresAt      DateTime? @db.Timestamptz
  
  @@index([tenantId])
  @@index([status])
  @@index([mpPreferenceId])
  @@map("payment_preferences")
}

// Notificaciones para administradores (pagos, alertas)
model AdminNotification {
  id          String   @id @default(uuid()) @db.Uuid
  
  type        String   // PAYMENT_RECEIVED, INVOICE_REQUIRED, SYSTEM_ALERT, etc.
  title       String
  message     String
  
  // Datos adicionales en JSON
  data        Json?
  
  // Estado
  isRead      Boolean  @default(false)
  readAt      DateTime? @db.Timestamptz
  
  // Link para acción (opcional)
  actionLink  String?
  actionLabel String?
  
  createdAt   DateTime @default(now()) @db.Timestamptz
  
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@map("admin_notifications")
}

// Configuración de MercadoPago
model MercadoPagoConfig {
  id          String   @id @default(uuid()) @db.Uuid
  
  accessToken String
  publicKey   String?
  webhookSecret String?
  
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz
  
  @@map("mercadopago_config")
}
model LicenseAccessAttempt {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId   String       @db.Uuid
  user     PlatformUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  module   String   // Nombre del módulo intentado
  path     String   // Ruta completa
  count    Int      @default(1)
  
  lastAttemptAt DateTime @default(now()) @db.Timestamptz

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@unique([tenantId, userId, module])
  @@index([tenantId])
  @@index([userId])
  @@map("license_access_attempts")
}

// Notificaciones de licencia (vencimientos, período de gracia, etc.)
model LicenseNotification {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId   String?       @db.Uuid
  user     PlatformUser? @relation(fields: [userId], references: [id], onDelete: Cascade)

  type     LicenseNotificationType
  title    String
  message  String
  
  // Mostrar hasta
  expiresAt DateTime? @db.Timestamptz
  
  // Estado
  isRead    Boolean  @default(false)
  readAt    DateTime? @db.Timestamptz
  
  // Acción tomada
  actionTaken String? // "UPGRADE", "DISMISS", etc.

  createdAt DateTime @default(now()) @db.Timestamptz

  @@index([tenantId])
  @@index([userId])
  @@index([type])
  @@map("license_notifications")
}

// Enums para el sistema de licencias
enum SetupStatus {
  PENDING
  PAID
  WAIVED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  DISPUTED
}

enum LicenseNotificationType {
  SETUP_REQUIRED
  TRIAL_STARTED
  TRIAL_ENDING_SOON
  TRIAL_ENDED
  SUBSCRIPTION_EXPIRING_7D
  SUBSCRIPTION_EXPIRING_3D
  SUBSCRIPTION_EXPIRING_1D
  SUBSCRIPTION_EXPIRED
  GRACE_PERIOD_STARTED
  GRACE_PERIOD_ENDING
  MODULE_BLOCKED
  UPGRADE_SUGGESTED
  PAYMENT_FAILED
  PAYMENT_SUCCESS
}

// Emergency & Disaster Management Models
enum DrillStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DrillType {
  NATURAL_DISASTER
  FIRE
  SECURITY_INCIDENT
  MEDICAL_EMERGENCY
  INFRASTRUCTURE_FAILURE
  PANDEMIC
  OTHER
}

enum SeverityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskActionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum RiskActionEffectiveness {
  PENDING
  EFFECTIVE
  NOT_EFFECTIVE
  PARTIAL
}

model DrillScenario {
  id          String @id @default(uuid()) @db.Uuid
  tenantId    String @db.Uuid
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String? @db.Text
  type        DrillType
  severity    SeverityLevel
  category    String @default("NATURAL_DISASTER")
  status      DrillStatus @default(PLANNED)

  objectives  Json? // Array of objectives
  scope       Json? // {areas: [], departments: [], participants: number, external_agencies: []}
  schedule    Json? // {plannedDate, duration, start_time, end_time}

  coordinator Json? // {id, name, email, phone}
  evaluators  Json? // Array of evaluator info
  resources   Json? // {equipment: [], personnel: [], facilities: []}
  procedures  Json? // Array of procedures
  evaluationCriteria Json? // Array of evaluation criteria

  results     Json? // Drill results and findings (legacy)

  // Execution tracking (ISO 14001/45001)
  scheduledDate   DateTime? @db.Timestamptz
  executionDate   DateTime? @db.Timestamptz
  responsibleId   String?  @db.Uuid

  // Linkages
  riskId                   String? @db.Uuid
  environmentalAspectId    String? @db.Uuid

  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz
  startedAt   DateTime? @db.Timestamptz
  completedAt DateTime? @db.Timestamptz

  createdById String? @db.Uuid
  createdBy   PlatformUser? @relation("DrillCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  deletedAt   DateTime? @db.Timestamptz

  // Relations
  responsible           Employee?          @relation("DrillResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  risk                  Hazard?            @relation("DrillHazard", fields: [riskId], references: [id], onDelete: SetNull)
  environmentalAspect   EnvironmentalAspect? @relation("DrillEnvironmentalAspect", fields: [environmentalAspectId], references: [id], onDelete: SetNull)
  participants          DrillParticipant[]
  drillResults          DrillResult[]
  drillActions          DrillAction[]
  nonConformities       NonConformity[]    @relation("NcrDrill")

  @@index([tenantId])
  @@index([status])
  @@index([type])
  @@index([severity])
  @@index([responsibleId])
  @@index([riskId])
  @@index([environmentalAspectId])
  @@map("drill_scenarios")
}

model DrillParticipant {
  id          String @id @default(uuid()) @db.Uuid
  tenantId    String @db.Uuid
  drillId     String @db.Uuid
  employeeId  String @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz

  drill       DrillScenario @relation(fields: [drillId], references: [id], onDelete: Cascade)
  employee    Employee      @relation("DrillParticipantEmployee", fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([drillId, employeeId])
  @@index([tenantId])
  @@index([drillId])
  @@index([employeeId])
  @@map("drill_participants")
}

model DrillResult {
  id                String @id @default(uuid()) @db.Uuid
  tenantId          String @db.Uuid
  drillId           String @db.Uuid
  result            String // SUCCESSFUL, WITH_FAILURES, CRITICAL
  responseTime      Int? // minutes
  observations      String? @db.Text
  deviationsDetected Boolean @default(false)
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz

  drill             DrillScenario @relation(fields: [drillId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([drillId])
  @@map("drill_results")
}

model DrillAction {
  id              String @id @default(uuid()) @db.Uuid
  tenantId        String @db.Uuid
  drillId         String @db.Uuid
  description     String
  responsibleId   String? @db.Uuid
  dueDate         DateTime? @db.Timestamptz
  status          RiskActionStatus @default(PENDING)
  effectiveness   RiskActionEffectiveness @default(PENDING)
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  drill           DrillScenario @relation(fields: [drillId], references: [id], onDelete: Cascade)
  responsible     Employee? @relation("DrillActionResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([drillId])
  @@index([status])
  @@map("drill_actions")
}

model ContingencyPlan {
  id          String @id @default(uuid()) @db.Uuid
  tenantId    String @db.Uuid
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String? @db.Text
  type        String // e.g., NATURAL_DISASTER, FIRE, SECURITY, etc.
  status      String @default("ACTIVE") // ACTIVE, OBSOLETE
  version     String @default("1.0")

  responsibleId String? @db.Uuid
  reviewDate    DateTime? @db.Timestamptz
  nextReviewDate DateTime? @db.Timestamptz

  objectives  Json? // Array of objectives
  triggers    Json? // Conditions that activate the plan
  responsibilities Json? // {role: [responsibilities]}
  procedures  Json? // Array of step-by-step procedures
  resources   Json? // {equipment: [], personnel: [], locations: []}
  communications Json? // Notification protocols and contact lists
  timeline    Json? // Timeline estimates for different phases

  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  createdById String? @db.Uuid
  createdBy   PlatformUser? @relation("PlanCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  deletedAt   DateTime? @db.Timestamptz

  // Relations
  responsible        Employee?               @relation("ContingencyPlanResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  versionHistory     ContingencyPlanVersion[]

  @@index([tenantId])
  @@index([status])
  @@index([responsibleId])
  @@map("contingency_plans")
}

model ContingencyPlanVersion {
  id          String @id @default(uuid()) @db.Uuid
  tenantId    String @db.Uuid
  planId      String @db.Uuid
  version     String
  content     Json // snapshot of plan data
  createdById String? @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz

  plan        ContingencyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([planId])
  @@map("contingency_plan_versions")
}

model EmergencyResource {
  id          String @id @default(uuid()) @db.Uuid
  tenantId    String @db.Uuid
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String? @db.Text
  type        String // e.g., EQUIPMENT, PERSONNEL, FACILITY, SUPPLY
  category    String? // e.g., MEDICAL, RESCUE, COMMUNICATION

  quantity    Int?
  location    String?
  status      String @default("AVAILABLE") // AVAILABLE, IN_USE, MAINTENANCE, UNAVAILABLE

  // ISO 14001/45001 operational status
  isOperational   Boolean @default(true)
  maintenanceDate   DateTime? @db.Timestamptz
  expirationDate    DateTime? @db.Timestamptz
  responsibleId   String? @db.Uuid

  contactInfo Json? // {name, phone, email}
  specifications Json? // Additional specs or details
  maintenanceSchedule Json? // Maintenance dates and history

  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  createdById String? @db.Uuid
  createdBy   PlatformUser? @relation("ResourceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  deletedAt   DateTime? @db.Timestamptz

  // Relations
  responsible Employee? @relation("EmergencyResourceResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@index([responsibleId])
  @@map("emergency_resources")
}

// Customer / Cliente model
model Customer {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code        String    // CLI-{YYYY}-{NNN}
  name        String
  legalName   String?   // Razón social
  taxId       String?   // CUIT/RUT/NIF
  email       String?
  phone       String?
  mobile      String?
  website     String?

  // Address
  address     String?
  city        String?
  state       String?
  country     String?
  zipCode     String?

  // Contact person
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  contactPosition String?

  // Classification
  type        String @default("CLIENT") // CLIENT, SUPPLIER, PARTNER, PROSPECT
  status      String @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED
  category    String? // A, B, C classification

  // Business info
  industry    String?
  employeesCount Int?
  annualRevenue  Float?

  // Notes
  notes       String?

  // Relations
  surveys     CustomerSurvey[]
  ncrLinks    NonConformity[] @relation("CustomerNCR")
  responses   SurveyResponse[]
  documents   Document[] @relation("CustomerDocuments")
  improvementPlans CustomerImprovementPlan[]

  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz
  createdById String? @db.Uuid
  createdBy   PlatformUser? @relation("CustomerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String? @db.Uuid
  updatedBy   PlatformUser? @relation("CustomerUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  deletedAt   DateTime? @db.Timestamptz

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@map("customers")
}

// Survey / Encuesta model
model Survey {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code        String    // SRV-{YYYY}-{NNN}
  title       String
  description String?
  type        String @default("SATISFACTION") // SATISFACTION, NPS, CUSTOM, POST_SERVICE

  // Configuration
  isActive    Boolean @default(true)
  isAnonymous Boolean @default(false)
  allowMultipleResponses Boolean @default(false)
  sendEmail   Boolean @default(false)
  emailSubject String?
  emailBody    String?

  // Scheduling
  startDate   DateTime?
  endDate     DateTime?

  // Relations
  questions   SurveyQuestion[]
  responses   SurveyResponse[]
  customers   CustomerSurvey[]

  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz
  createdById String? @db.Uuid
  createdBy   PlatformUser? @relation("SurveyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String? @db.Uuid
  updatedBy   PlatformUser? @relation("SurveyUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  deletedAt   DateTime? @db.Timestamptz

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("surveys")
}

// Survey Question / Pregunta de encuesta
model SurveyQuestion {
  id          String    @id @default(uuid()) @db.Uuid
  surveyId    String    @db.Uuid
  survey      Survey    @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  order       Int       @default(0)
  text        String
  description String?
  type        String    // RATING, SINGLE_CHOICE, MULTIPLE_CHOICE, TEXT, NPS, YES_NO, SCALE

  // Configuration
  isRequired  Boolean @default(true)
  minValue    Int?      // For RATING/SCALE
  maxValue    Int?      // For RATING/SCALE
  scaleLabels Json?     // {min: "Muy insatisfecho", max: "Muy satisfecho"}

  // Options for choice questions
  options     SurveyOption[]

  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  @@index([surveyId])
  @@index([surveyId, order])
  @@map("survey_questions")
}

// Survey Option / Opción de respuesta
model SurveyOption {
  id          String    @id @default(uuid()) @db.Uuid
  questionId  String    @db.Uuid
  question    SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  order       Int       @default(0)
  value       String
  label       String

  createdAt   DateTime @default(now()) @db.Timestamptz

  @@index([questionId])
  @@index([questionId, order])
  @@map("survey_options")
}

// Customer Survey Link / Vinculación cliente-encuesta
model CustomerSurvey {
  id          String    @id @default(uuid()) @db.Uuid
  customerId  String    @db.Uuid
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  surveyId    String    @db.Uuid
  survey      Survey    @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  status      String @default("PENDING") // PENDING, SENT, COMPLETED, EXPIRED
  sentAt      DateTime?
  completedAt DateTime?
  token       String    @unique // Unique token for survey link

  createdAt   DateTime @default(now()) @db.Timestamptz

  @@unique([customerId, surveyId])
  @@index([customerId])
  @@index([surveyId])
  @@index([token])
  @@map("customer_surveys")
}

// Survey Response / Respuesta a encuesta
model SurveyResponse {
  id          String    @id @default(uuid()) @db.Uuid
  surveyId    String    @db.Uuid
  survey      Survey    @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  customerId  String?   @db.Uuid
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // Anonymous response info
  respondentName  String?
  respondentEmail String?
  respondentPhone String?

  // Response data
  answers     SurveyAnswer[]
  npsScore    Int?      // 0-10 for NPS
  satisfactionScore Float? // Calculated from answers
  comments    String?

  // Status
  isComplete  Boolean @default(false)
  completedAt DateTime?
  ipAddress   String?
  userAgent   String?

  createdAt   DateTime @default(now()) @db.Timestamptz

  @@index([surveyId])
  @@index([customerId])
  @@index([surveyId, customerId])
  @@map("survey_responses")
}

// Survey Answer / Respuesta individual
model SurveyAnswer {
  id          String    @id @default(uuid()) @db.Uuid
  responseId  String    @db.Uuid
  response    SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  questionId  String    @db.Uuid
  questionText String   // Snapshot of question text at time of response

  // Answer value (flexible storage)
  value       String?   // String value
  numericValue Float?   // Numeric value (for ratings, NPS, etc.)
  textValue   String?   // Text response
  selectedOptions Json? // Array of selected option IDs

  createdAt   DateTime @default(now()) @db.Timestamptz

  @@index([responseId])
  @@index([questionId])
  @@map("survey_answers")
}

// ═══════════════════════════════════════════════════════════════
// Módulo de Mantenimiento Industrial
// ═══════════════════════════════════════════════════════════════

model MaintenanceAsset {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code        String   @unique
  name        String
  description String?
  category    String   @default("OTHER") // MACHINERY, VEHICLE, TOOL, INFRASTRUCTURE, ELECTRONIC, SAFETY, OTHER
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE, MAINTENANCE

  location    String?
  department  String?
  manufacturer String?
  model       String?
  serialNumber String?

  purchaseDate     DateTime?
  warrantyDate     DateTime?
  acquisitionCost  Float    @default(0)

  totalMaintenanceCost Float @default(0)
  lastMaintenanceDate  DateTime?
  nextMaintenanceDate  DateTime?

  workOrders   WorkOrder[]
  plans        MaintenancePlan[]
  costs        MaintenanceCost[]

  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  @@index([tenantId])
  @@index([code])
  @@map("maintenance_assets")
}

model MaintenanceTechnician {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code        String   @unique
  name        String
  email       String?
  phone       String?
  specialization String?
  certification  String?

  isActive    Boolean  @default(true)
  availabilityStatus String @default("AVAILABLE") // AVAILABLE, BUSY, OFF

  workOrders  WorkOrder[]

  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  @@index([tenantId])
  @@index([code])
  @@map("maintenance_technicians")
}

model MaintenancePlan {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code        String   @unique
  title       String
  description String?
  type        String   @default("PREVENTIVE") // PREVENTIVE, CORRECTIVE, PREDICTIVE, EMERGENCY
  status      String   @default("ACTIVE") // ACTIVE, PAUSED, INACTIVE

  assetId     String?  @db.Uuid
  asset       MaintenanceAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)

  frequencyValue Int    @default(30)
  frequencyUnit  String @default("DAYS") // DAYS, WEEKS, MONTHS, YEARS

  nextExecutionDate   DateTime?
  lastExecutionDate DateTime?
  totalExecutions     Int     @default(0)

  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  @@index([tenantId])
  @@index([assetId])
  @@map("maintenance_plans")
}

model MaintenanceSparePart {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code        String   @unique
  name        String
  description String?
  category    String?

  currentStock Int    @default(0)
  minStock     Int    @default(0)
  maxStock     Int?
  unitCost     Float  @default(0)

  supplier     String?
  supplierCode String?
  location     String?

  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  @@index([tenantId])
  @@index([code])
  @@map("maintenance_spare_parts")
}

model WorkOrder {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code        String   @unique
  title       String
  description String?

  type        String   @default("CORRECTIVE") // PREVENTIVE, CORRECTIVE, PREDICTIVE, EMERGENCY
  priority    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED, ON_HOLD

  assetId     String   @db.Uuid
  asset       MaintenanceAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  technicianId String? @db.Uuid
  technician   MaintenanceTechnician? @relation(fields: [technicianId], references: [id], onDelete: SetNull)

  scheduledDate DateTime?
  startedAt     DateTime?
  completedAt   DateTime?

  estimatedDuration Int? // hours
  actualDuration    Int? // hours

  laborCost  Float @default(0)
  partsCost  Float @default(0)
  totalCost  Float @default(0)

  costs      MaintenanceCost[]

  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  @@index([tenantId])
  @@index([assetId])
  @@index([technicianId])
  @@index([status])
  @@map("work_orders")
}

model MaintenanceCost {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  costType    String   @default("PREVENTIVE") // PREVENTIVE, CORRECTIVE, PREDICTIVE, EMERGENCY
  amount      Float
  description String?
  date        DateTime @default(now())

  assetId     String   @db.Uuid
  asset       MaintenanceAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  workOrderId String?  @db.Uuid
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now()) @db.Timestamptz

  @@index([tenantId])
  @@index([assetId])
  @@index([workOrderId])
  @@map("maintenance_costs")
}

model CompanyRegistration {
  id          String   @id @default(uuid()) @db.Uuid
  companyName String
  socialReason String?
  rut         String   @unique
  email       String
  phone       String
  website     String?
  address     String
  primaryColor String  @default("#3B82F6")
  module      String   @default("sgi360")
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  
  // ID de tenant cuando se aprueba (sin relación compleja)
  tenantId    String?  @db.Uuid
  
  // Datos de quien aprobó y cuándo
  approvedBy  String?  @db.Uuid
  approvedAt  DateTime?
  notes       String?
  
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz
  
  @@index([status])
  @@index([email])
  @@index([tenantId])
  @@map("company_registrations")
}

// Historial de contraseñas de usuarios
model PasswordHistory {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  user        PlatformUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Contraseña hasheada
  passwordHash String
  
  // Tipo de cambio
  changeType   String   @default("USER_CHANGE") // USER_CHANGE, ADMIN_RESET, TEMPORARY, INITIAL
  
  // Quién realizó el cambio
  changedBy    String?  @db.Uuid
  changedByUser PlatformUser? @relation("PasswordChangedBy", fields: [changedBy], references: [id])
  
  // Metadatos
  reason       String?
  ipAddress    String?
  userAgent    String?
  
  createdAt    DateTime @default(now()) @db.Timestamptz
  
  @@index([userId])
  @@index([changedBy])
  @@index([createdAt])
  @@map("password_history")
}


// ============================================================
// MÓDULOS SGI PROFESIONAL - Agregados Abr 2026
// ============================================================

// -------- 1. ACCIONES (CAPA transversal) --------
model ActionItem {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code          String
  title         String
  description   String
  type          String    // CORRECTIVE, PREVENTIVE, IMPROVEMENT
  priority      String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status        String    @default("OPEN") // OPEN, IN_PROGRESS, VERIFICATION, CLOSED, CANCELLED
  sourceType    String    // MANUAL, AUDIT, NCR, INDICATOR, REVIEW, RISK, INCIDENT, SUGGESTION
  sourceId      String?   @db.Uuid
  assignedToId  String?   @db.Uuid
  openDate      DateTime?  @db.Timestamptz
  dueDate       DateTime?
  completedAt   DateTime?
  // Campos de evaluación de riesgo (estilo Matriz de Riesgos)
  initialProbability Int?      @default(1) // 1-5
  initialImpact     Int?      @default(1) // 1-5
  initialRiskLevel  String?   // LOW, MEDIUM, HIGH, CRITICAL (calculado)
  residualProbability Int?    @default(1) // 1-5
  residualImpact     Int?    @default(1) // 1-5
  residualRiskLevel  String? // LOW, MEDIUM, HIGH, CRITICAL (calculado)
  riskReduction      Float?   // % de reducción (calculado)
  // -------- SECCIÓN 1: IDENTIFICACIÓN --------
  origin        String?   // AUDIT, CLIENT, PROCESS, STAKEHOLDER, MANUAL
  affectedArea  String?
  detectedBy    String?

  // -------- SECCIÓN 2: CONTENCIÓN --------
  containmentActions    String?
  containmentResponsibleId String? @db.Uuid
  containmentImplementedAt DateTime?
  containmentResult     String?

  // -------- SECCIÓN 3: CAUSA RAÍZ --------
  rootCauseMethod       String?   // FIVE_WHY, ISHIKAWA, OTHER
  rootCause             String?
  rootCauseEvidence     String?

  // -------- SECCIÓN 4: ACCIÓN CORRECTIVA --------
  correctiveAction      String?
  correctiveResponsibleId String? @db.Uuid
  correctiveDueDate     DateTime?
  correctiveResources   String?

  // -------- SECCIÓN 5: ACCIÓN PREVENTIVA --------
  preventiveAction      String?
  processChanges        String?
  documentationChanges  String?

  // -------- SECCIÓN 6: EVALUACIÓN DE EFICACIA --------
  verificationMethod    String?
  relatedIndicatorId  String?   @db.Uuid
  effectivenessResult String?   // EFFECTIVE, NOT_EFFECTIVE
  effectivenessEvaluatedAt DateTime?

  // -------- SECCIÓN 7: CIERRE --------
  closedAt            DateTime?
  approvedById        String?   @db.Uuid
  closureComments     String?

  // -------- PROGRESO --------
  progress            Int       @default(0)

  // Campos existentes (mantenidos)
  effectivenessCheck String?
  effectivenessVerifiedAt DateTime?
  effectivenessVerifiedById String? @db.Uuid
  notes         String?
  createdById   String?   @db.Uuid
  updatedById   String?   @db.Uuid
  deletedAt     DateTime?
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz

  @@index([tenantId])
  @@index([status])
  @@index([assignedToId])
  @@index([sourceType, sourceId])
  @@map("action_items")
}

// -------- 2. POLÍTICAS --------
model Policy {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  content     String?
  scope       String?  // Calidad, Ambiente, Seguridad, Integrado
  active      Boolean  @default(true)
  deletedAt   DateTime?
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  sgiObjectives SgiObjective[]

  @@index([tenantId])
  @@map("policies")
}

// -------- 2b. OBJETIVOS SGI --------
model SgiObjective {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  code          String
  title         String
  description   String?
  year          Int
  standard      String?
  target        String
  targetValue   Float?
  unit          String?
  type          String?   @default("STRATEGIC") // STRATEGIC | OPERATIONAL
  sites         String[]  @default([])
  responsibleId String?   @db.Uuid
  startDate     DateTime?
  endDate       DateTime?
  status        String    @default("PLANNED") // PLANNED, IN_PROGRESS, ACHIEVED, NOT_ACHIEVED, CANCELLED
  progress      Int       @default(0)
  indicatorId   String?   @db.Uuid
  notes         String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz

  // Relaciones
  policyId      String?   @db.Uuid
  policy        Policy?   @relation(fields: [policyId], references: [id], onDelete: SetNull)

  processId     String?   @db.Uuid
  process       Process?  @relation(fields: [processId], references: [id], onDelete: SetNull)

  activities    ObjectiveActivity[]
  indicators    ObjectiveIndicator[]
  audits        ObjectiveAudit[]
  capas         ObjectiveCAPA[]
  risks         ObjectiveRisk[]

  @@index([tenantId])
  @@index([year])
  @@index([policyId])
  @@index([processId])
  @@map("sgi_objectives")
}

// -------- 2c. RELACIONES OBJETIVO --------
model ObjectiveActivity {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  objectiveId   String    @db.Uuid
  objective     SgiObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  name          String
  responsibleId String?   @db.Uuid
  startDate     DateTime?
  endDate       DateTime?
  status        String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz

  @@index([tenantId])
  @@index([objectiveId])
  @@map("objective_activities")
}

model ObjectiveIndicator {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  objectiveId   String    @db.Uuid
  objective     SgiObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  indicatorId   String    @db.Uuid
  createdAt     DateTime  @default(now()) @db.Timestamptz

  @@index([tenantId])
  @@index([objectiveId])
  @@index([indicatorId])
  @@map("objective_indicators")
}

model ObjectiveAudit {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  objectiveId   String    @db.Uuid
  objective     SgiObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  auditId       String    @db.Uuid
  createdAt     DateTime  @default(now()) @db.Timestamptz

  @@index([tenantId])
  @@index([objectiveId])
  @@index([auditId])
  @@map("objective_audits")
}

model ObjectiveCAPA {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  objectiveId   String    @db.Uuid
  objective     SgiObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  capaId        String    @db.Uuid
  createdAt     DateTime  @default(now()) @db.Timestamptz

  @@index([tenantId])
  @@index([objectiveId])
  @@index([capaId])
  @@map("objective_capas")
}

model ObjectiveRisk {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  objectiveId   String    @db.Uuid
  objective     SgiObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  riskId        String    @db.Uuid
  createdAt     DateTime  @default(now()) @db.Timestamptz

  @@index([tenantId])
  @@index([objectiveId])
  @@index([riskId])
  @@map("objective_risks")
}

// -------- 3. PARTES INTERESADAS --------
model Stakeholder {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  name          String
  type          String    // INTERNAL, EXTERNAL
  category      String    // EMPLOYEE, CUSTOMER, SUPPLIER, COMMUNITY, REGULATOR, SHAREHOLDER, OTHER
  needs         String?
  expectations  String?
  requirements  String?
  influence     Int       @default(3)
  interest      Int       @default(3)
  contactName   String?
  contactEmail  String?
  notes         String?
  // Evaluación de cumplimiento (ISO 9001 cláusulas 4.2 y 9.1)
  complianceStatus      String?   @map("compliance_status") // COMPLIES, PARTIAL, NON_COMPLIANT
  complianceLevel       Int?      @map("compliance_level") // 0-100
  lastEvaluationDate    DateTime? @map("last_evaluation_date") @db.Timestamptz
  complianceEvidence    String?   @map("compliance_evidence")
  indicatorId           String?   @map("indicator_id") @db.Uuid
  requiresAction        Boolean?  @map("requires_action") @default(false)
  actionItemId          String?   @map("action_item_id") @db.Uuid
  deletedAt     DateTime?
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz

  @@index([tenantId])
  @@index([complianceStatus])
  @@map("stakeholders")
}

// -------- 3b. CONTEXTO ORGANIZACIONAL (FODA/PESTEL) --------
model OrganizationContext {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  year          Int
  strengths     Json?
  weaknesses    Json?
  opportunities Json?
  threats       Json?
  political     String?
  economic      String?
  social        String?
  technological String?
  environmental String?
  legal         String?
  mission       String?
  vision        String?
  values        String?
  dafoFo        String?
  dafoFa        String?
  dafoDo        String?
  dafoDa        String?
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz

  @@unique([tenantId, year])
  @@map("organization_context")
}

// -------- PROJECT360 --------
model Project360 {
  id            String              @id @default(uuid()) @db.Uuid
  tenantId      String              @db.Uuid
  code          String
  name          String
  description   String?
  origin        String
  originModule  String              @default("PROJECT360")
  originEntityId String?
  responsibleId String              @db.Uuid
  targetDate    DateTime            @db.Timestamptz
  startDate     DateTime            @default(now()) @db.Timestamptz
  status        String              @default("PENDING")
  priority      String              @default("MEDIUM")
  progress      Int                 @default(0)
  tags          Json                @default("[]")
  indicatorId   String?             @db.Uuid
  targetValue   Float?
  createdById   String?             @db.Uuid
  createdAt     DateTime            @default(now()) @db.Timestamptz
  updatedAt     DateTime            @updatedAt @db.Timestamptz
  deletedAt     DateTime?           @db.Timestamptz

  tasks         Project360Task[]
  attachments   Project360Attachment[]
  reminders     Project360Reminder[]
  history       Project360History[]

  @@map("project360")
}

model Project360Task {
  id            String    @id @default(uuid()) @db.Uuid
  projectId     String    @db.Uuid
  tenantId      String    @db.Uuid
  title         String
  description   String?
  responsibleId String?   @db.Uuid
  status        String    @default("PENDING")
  priority      String    @default("MEDIUM")
  dueDate       DateTime? @db.Timestamptz
  completedAt   DateTime? @db.Timestamptz
  order         Int       @default(0)
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz
  deletedAt     DateTime? @db.Timestamptz

  project       Project360  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comments      Project360Comment[]

  @@map("project360_task")
}

model Project360Comment {
  id          String    @id @default(uuid()) @db.Uuid
  taskId      String    @db.Uuid
  tenantId    String    @db.Uuid
  text        String
  authorId    String?   @db.Uuid
  authorName  String?
  createdAt   DateTime  @default(now()) @db.Timestamptz

  task        Project360Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("project360_comment")
}

model Project360Attachment {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @db.Uuid
  taskId      String?   @db.Uuid
  tenantId    String    @db.Uuid
  name        String
  url         String
  size        Int       @default(0)
  type        String    @default("application/octet-stream")
  uploadedById String?  @db.Uuid
  createdAt   DateTime  @default(now()) @db.Timestamptz

  project     Project360 @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project360_attachment")
}

model Project360Reminder {
  id            String    @id @default(uuid()) @db.Uuid
  projectId     String    @db.Uuid
  tenantId      String    @db.Uuid
  title         String
  description   String?
  reminderDate  DateTime  @db.Timestamptz
  userId        String?   @db.Uuid
  isCompleted   Boolean   @default(false)
  completedAt   DateTime? @db.Timestamptz
  createdAt     DateTime  @default(now()) @db.Timestamptz

  project       Project360 @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project360_reminder")
}

model Project360History {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @db.Uuid
  tenantId    String    @db.Uuid
  action      String
  details     String?
  userId      String?   @db.Uuid
  userName    String?
  createdAt   DateTime  @default(now()) @db.Timestamptz

  project     Project360 @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project360_history")
}

// -------- Gestión de Cambios (ISO 6.3) --------
model GestionCambio {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @db.Uuid
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code            String
  titulo          String
  descripcion     String
  tipo            String    // PROCESO | ORGANIZACIONAL | PRODUCTO_SERVICIO | INFRAESTRUCTURA | PROVEEDOR | NORMATIVO | OTRO
  origen          String    // AUDITORIA | NO_CONFORMIDAD | MEJORA | CLIENTE | LEGAL | INTERNO | OTRO
  impactoCalidad  String    // BAJO | MEDIO | ALTO
  impactoSST      String    // BAJO | MEDIO | ALTO
  impactoAmbiental String   // BAJO | MEDIO | ALTO
  status          String    @default("SOLICITADO") // SOLICITADO | EN_REVISION | APROBADO | RECHAZADO | IMPLEMENTADO | VERIFICADO | CERRADO
  responsableId   String?   @db.Uuid
  aprobadorId     String?   @db.Uuid
  fechaSolicitud  DateTime  @default(now()) @db.Timestamptz
  fechaPrevista   DateTime? @db.Timestamptz
  fechaAprobacion DateTime? @db.Timestamptz
  fechaCierre     DateTime? @db.Timestamptz
  motivoRechazo   String?
  recursosNecesarios String?
  capacitacionRequerida Boolean @default(false)
  documentosAfectados String?
  riesgosIdentificados String?
  verificacion    String?
  creadoPor       String?
  deletedAt       DateTime? @db.Timestamptz
  createdAt       DateTime  @default(now()) @db.Timestamptz
  updatedAt       DateTime  @updatedAt @db.Timestamptz

  historial       GestionCambioHistorial[]

  @@map("gestion_cambio")
}

model GestionCambioHistorial {
  id        String   @id @default(uuid()) @db.Uuid
  cambioId  String   @db.Uuid
  tenantId  String   @db.Uuid
  accion    String
  detalle   String?
  userId    String?  @db.Uuid
  userName  String?
  createdAt DateTime @default(now()) @db.Timestamptz

  cambio    GestionCambio @relation(fields: [cambioId], references: [id], onDelete: Cascade)

  @@map("gestion_cambio_historial")
}

enum HazardStatus {
  OPEN
  IN_TREATMENT
  CONTROLLED
  CLOSED
}

enum ReviewFrequency {
  MONTHLY
  QUARTERLY
  ANNUAL
}

// -------- 5. IPERC (Peligros SST) --------
model Hazard {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  code          String
  area          String
  activity      String
  hazard        String
  risk          String
  probability   Int
  severity      Int
  exposure      Int       @default(1)
  riskLevel     Int
  riskCategory  String    // TOLERABLE, MODERATE, SUBSTANTIAL, INTOLERABLE
  elimination   String?
  substitution  String?
  engineering   String?
  administrative String?
  ppe           String?
  residualRiskLevel    Int?
  residualRiskCategory String?
  responsibleId String?   @db.Uuid
  reviewDate    DateTime?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz

  // ISO 45001 extended fields
  status            HazardStatus     @default(OPEN)
  reviewFrequency   ReviewFrequency  @default(ANNUAL)

  // Control implementation tracking
  eliminationImplemented     Boolean? @default(false)
  substitutionImplemented    Boolean? @default(false)
  engineeringImplemented     Boolean? @default(false)
  administrativeImplemented  Boolean? @default(false)
  ppeImplemented           Boolean? @default(false)

  // Control effectiveness
  eliminationEffective     Boolean?
  substitutionEffective    Boolean?
  engineeringEffective     Boolean?
  administrativeEffective  Boolean?
  ppeEffective           Boolean?

  // Control observations
  eliminationObservation     String?
  substitutionObservation    String?
  engineeringObservation     String?
  administrativeObservation  String?
  ppeObservation           String?

  // Relations
  actions    RiskAction[]
  reviews    RiskReview[]
  nonConformities NonConformity[] @relation("NcrHazard")
  drills     DrillScenario[] @relation("DrillHazard")

  @@index([tenantId])
  @@map("hazards")
}

model RiskAction {
  id              String                @id @default(uuid()) @db.Uuid
  tenantId        String                @db.Uuid
  hazardId        String                @db.Uuid
  description     String
  responsibleId   String?               @db.Uuid
  dueDate         DateTime?
  status          RiskActionStatus      @default(PENDING)
  effectiveness   RiskActionEffectiveness @default(PENDING)
  evidence        String?
  createdAt       DateTime              @default(now()) @db.Timestamptz
  updatedAt       DateTime              @updatedAt @db.Timestamptz

  hazard          Hazard                @relation(fields: [hazardId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([hazardId])
  @@map("risk_actions")
}

model RiskReview {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  hazardId    String    @db.Uuid
  reviewDate  DateTime  @default(now()) @db.Timestamptz
  result      String    // CONTROLLED, NOT_CONTROLLED
  comments    String?
  reviewedById String?  @db.Uuid

  hazard      Hazard    @relation(fields: [hazardId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([hazardId])
  @@map("risk_reviews")
}

// -------- 6. ASPECTOS AMBIENTALES --------
model EnvironmentalAspect {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  code          String
  process       String
  aspect        String
  impact        String
  category      String    // EMISSIONS, WASTE, ENERGY, WATER, SOIL, BIODIVERSITY, NOISE, OTHER
