model SupplierEvaluation {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  supplierId    String    @db.Uuid
  supplier      Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  date          DateTime
  period        String?
  qualityScore  Float     @default(0) // calidad
  deliveryScore Float     @default(0) // cumplimiento
  priceScore    Float     @default(0) // precio
  serviceScore  Float     @default(0) // servicio
  documentationScore Float @default(0) // documentacion
  overallScore  Float     @default(0)
  result        String    // APPROVED, CONDITIONAL, REJECTED
  comments      String?
  evaluatedById String?   @db.Uuid
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz

  @@index([supplierId])
  @@index([tenantId])
  @@map("supplier_evaluations")
}

// -------- 9. CALIBRACIONES --------
model MeasuringEquipment {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  code          String
  name          String
  type          String?
  brand         String?
  model         String?
  serialNumber  String?
  location      String?
  responsibleId String?   @db.Uuid
  status        String    @default("ACTIVE") // ACTIVE, OUT_OF_SERVICE, RETIRED
  calibrationFrequency String @default("YEARLY") // MONTHLY, QUARTERLY, BIANNUAL, YEARLY, OTHER
  lastCalibrationDate DateTime?
  nextCalibrationDate DateTime?
  acquisitionDate DateTime?
  notes         String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz

  calibrations  Calibration[]

  @@index([tenantId])
  @@index([nextCalibrationDate])
  @@map("measuring_equipment")
}

model Calibration {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  equipmentId   String    @db.Uuid
  equipment     MeasuringEquipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  date          DateTime
  provider      String?
  certificateNumber String?
  certificateUrl String?
  result        String    // CONFORMING, CONFORMING_WITH_ADJUSTMENT, NON_CONFORMING
  notes         String?
  nextCalibrationDate DateTime?
  cost          Float?
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz

  @@index([equipmentId])
  @@index([tenantId])
  @@map("calibrations")
}

model ProcessMap {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @db.Uuid
  tenant      Tenant  @relation(fields: [tenantId], references: [id])

  name        String
  description String?
  scope       String?
  inputLabel  String? @default("Requisitos del cliente / PI")
  outputLabel String? @default("Satisfacción del cliente / PI")

  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz
  deletedAt   DateTime? @db.Timestamptz

  createdById String?       @db.Uuid
  createdBy   PlatformUser? @relation("ProcessMapCreatedBy", fields: [createdById], references: [id])

  processes   Process[]

  @@index([tenantId])
  @@map("process_maps")
}

model Process {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String     @db.Uuid
  processMapId String     @db.Uuid
  processMap   ProcessMap @relation(fields: [processMapId], references: [id], onDelete: Cascade)

  layer        String     // STRATEGIC | OPERATIONAL | SUPPORT
  name         String
  code         String?    // OP-01, PE-02, etc.
  status       String     @default("active") // active | inactive
  description  String?
  owner        String?
  inputs       String?
  outputs      String?
  sites        String[]   @default([]) // multi-sede
  departmentId String?    @db.Uuid

  // Legacy fields (mapeados a columnas existentes en la DB)
  indicators   String?  @map("indicators_legacy")
  documents    String?  @map("documents_legacy")
  risks        String?  @map("risks_legacy")

  order        Int        @default(0)

  // Relaciones con entidades reales
  processIndicators ProcessIndicator[]
  processDocuments  ProcessDocument[]
  processRisks      ProcessRisk[]
  sgiObjectives     SgiObjective[]

  createdAt    DateTime  @default(now()) @db.Timestamptz
  updatedAt    DateTime  @updatedAt @db.Timestamptz
  deletedAt    DateTime? @db.Timestamptz

  @@index([processMapId])
  @@index([tenantId])
  @@unique([tenantId, code])
  @@map("processes")
}

model ProcessIndicator {
  id          String @id @default(uuid()) @db.Uuid
  processId   String @db.Uuid
  process     Process @relation(fields: [processId], references: [id], onDelete: Cascade)
  indicatorId String @db.Uuid

  @@index([processId])
  @@index([indicatorId])
  @@unique([processId, indicatorId])
  @@map("process_indicators")
}

model ProcessDocument {
  id         String @id @default(uuid()) @db.Uuid
  processId  String @db.Uuid
  process    Process @relation(fields: [processId], references: [id], onDelete: Cascade)
  documentId String @db.Uuid

  @@index([processId])
  @@index([documentId])
  @@unique([processId, documentId])
  @@map("process_documents")
}

model ProcessRisk {
  id        String @id @default(uuid()) @db.Uuid
  processId String @db.Uuid
  process   Process @relation(fields: [processId], references: [id], onDelete: Cascade)
  riskId    String @db.Uuid

  @@index([processId])
  @@index([riskId])
  @@unique([processId, riskId])
  @@map("process_risks")
}

// ═══════════════════════════════════════════════════════════
// Módulo de Clientes — Planes de Mejora
// ═══════════════════════════════════════════════════════════
model CustomerImprovementPlan {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  customerId String   @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  title       String
  description String?
  actions     String?
  responsible String?
  dueDate     DateTime? @db.Timestamptz
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, COMPLETED, CANCELLED

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@index([tenantId])
  @@index([customerId])
  @@map("customer_improvement_plans")
}
