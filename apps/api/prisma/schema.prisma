enum HazardStatus {
  OPEN
  IN_TREATMENT
  CONTROLLED
  CLOSED
}

enum ReviewFrequency {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum RiskActionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum RiskActionEffectiveness {
  EFFECTIVE
  NOT_EFFECTIVE
  PENDING
}

// -------- 5. IPERC (Peligros SST) --------
model Hazard {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  code          String
  area          String
  activity      String
  hazard        String
  risk          String
  probability   Int
  severity      Int
  exposure      Int       @default(1)
  riskLevel     Int
  riskCategory  String    // TOLERABLE, MODERATE, SUBSTANTIAL, INTOLERABLE
  elimination   String?
  substitution  String?
  engineering   String?
  administrative String?
  ppe           String?
  residualRiskLevel    Int?
  residualRiskCategory String?
  responsibleId String?   @db.Uuid
  reviewDate    DateTime?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz

  // ISO 45001 extended fields
  status            HazardStatus     @default(OPEN)
  reviewFrequency   ReviewFrequency  @default(ANNUAL)

  // Control implementation tracking
  eliminationImplemented     Boolean? @default(false)
  substitutionImplemented    Boolean? @default(false)
  engineeringImplemented     Boolean? @default(false)
  administrativeImplemented  Boolean? @default(false)
  ppeImplemented           Boolean? @default(false)

  // Control effectiveness
  eliminationEffective     Boolean?
  substitutionEffective    Boolean?
  engineeringEffective     Boolean?
  administrativeEffective  Boolean?
  ppeEffective           Boolean?

  // Control observations
  eliminationObservation     String?
  substitutionObservation    String?
  engineeringObservation     String?
  administrativeObservation  String?
  ppeObservation           String?

  // Relations
  actions    RiskAction[]
  reviews    RiskReview[]
  nonConformities NonConformity[] @relation("NcrHazard")
  drills     DrillScenario[] @relation("DrillHazard")

  @@index([tenantId])
  @@map("hazards")
}

model RiskAction {
  id              String                @id @default(uuid()) @db.Uuid
  tenantId        String                @db.Uuid
  hazardId        String                @db.Uuid
  description     String
  responsibleId   String?               @db.Uuid
  dueDate         DateTime?
  status          RiskActionStatus      @default(PENDING)
  effectiveness   RiskActionEffectiveness @default(PENDING)
  evidence        String?
  createdAt       DateTime              @default(now()) @db.Timestamptz
  updatedAt       DateTime              @updatedAt @db.Timestamptz

  hazard          Hazard                @relation(fields: [hazardId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([hazardId])
  @@map("risk_actions")
}

model RiskReview {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  hazardId    String    @db.Uuid
  reviewDate  DateTime  @default(now()) @db.Timestamptz
  result      String    // CONTROLLED, NOT_CONTROLLED
  comments    String?
  reviewedById String?  @db.Uuid

  hazard      Hazard    @relation(fields: [hazardId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([hazardId])
  @@map("risk_reviews")
}

// -------- 6. ASPECTOS AMBIENTALES --------
model EnvironmentalAspect {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  code          String
  process       String
  aspect        String
  impact        String
  category      String    // EMISSIONS, WASTE, ENERGY, WATER, SOIL, BIODIVERSITY, NOISE, OTHER
  condition     String    @default("NORMAL") // NORMAL, ABNORMAL, EMERGENCY
  naturalness   String    @default("DIRECT") // DIRECT, INDIRECT
  magnitude     Int
  severity      Int
  frequency     Int
  legalCompliance Int     @default(3)
  significance      Int
  initialSignificance Int?
  isSignificant     Boolean   @default(false)
  currentControls String?
  improvementActions String?
  responsibleId String?   @db.Uuid
  reviewDate    DateTime?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz

  status        HazardStatus @default(OPEN)
  reviewFrequency ReviewFrequency?

  responsible     Employee? @relation("EnvironmentalAspectResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  actions         EnvironmentalAction[]
  controls        EnvironmentalControl[]
  reviews         EnvironmentalReview[]
  nonConformities NonConformity[] @relation("NcrEnvironmentalAspect")
  drills          DrillScenario[] @relation("DrillEnvironmentalAspect")

  @@index([tenantId])
  @@index([status])
  @@index([responsibleId])
  @@map("environmental_aspects")
}

model EnvironmentalAction {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  aspectId      String    @db.Uuid
  description   String
  responsibleId String?   @db.Uuid
  dueDate       DateTime? @db.Timestamptz
  status        RiskActionStatus @default(PENDING)
  effectiveness RiskActionEffectiveness @default(PENDING)
  evidence      String?
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz

  aspect      EnvironmentalAspect @relation(fields: [aspectId], references: [id], onDelete: Cascade)
  responsible Employee? @relation("EnvironmentalActionAssigned", fields: [responsibleId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([aspectId])
  @@index([status])
  @@map("environmental_actions")
}

model EnvironmentalControl {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  aspectId    String    @db.Uuid
  type        String    // OPERATIONAL, ENGINEERING, ADMINISTRATIVE
  description String
  implemented Boolean   @default(false)
  effective   Boolean   @default(false)
  observation String?
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz

  aspect EnvironmentalAspect @relation(fields: [aspectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([aspectId])
  @@map("environmental_controls")
}

model EnvironmentalReview {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @db.Uuid
  aspectId     String    @db.Uuid
  reviewDate   DateTime  @db.Timestamptz
  result       String    // CONTROLLED, NOT_CONTROLLED
  comments     String?
  reviewedById String?   @db.Uuid
  createdAt    DateTime  @default(now()) @db.Timestamptz
  updatedAt    DateTime  @updatedAt @db.Timestamptz

  aspect     EnvironmentalAspect @relation(fields: [aspectId], references: [id], onDelete: Cascade)
  reviewedBy Employee? @relation("EnvironmentalReviewBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([aspectId])
  @@index([reviewDate])
  @@map("environmental_reviews")
}

// -------- 7. INCIDENTES / ACCIDENTES --------
