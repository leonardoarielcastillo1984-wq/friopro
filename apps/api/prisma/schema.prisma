generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "debian-openssl-3.0.x"]
}

model NonConformity {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code        String
  title       String
  description String

  severity NCRSeverity
  source   NCRSource
  status   NCRStatus @default(OPEN)

  standard       String?
  clause         String?
  rootCause      String?
  analysisMethod String?
  correctiveAction String?
  preventiveAction String?

  detectedAt DateTime @default(now()) @db.Timestamptz
  dueDate    DateTime? @db.Timestamptz
  closedAt   DateTime? @db.Timestamptz

  verificationNotes String?
  verificationDate  DateTime? @db.Timestamptz
  isEffective       Boolean?

  assignedToId String?       @db.Uuid
  assignedTo   PlatformUser? @relation("NcrAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  aiFindingId String? @db.Uuid

  // Proceso asociado para análisis de riesgo
  processId String? @db.Uuid
  process   String? // Nombre del proceso para análisis IA

  // Trazabilidad desde Indicadores (KPI)
  indicatorId            String?               @db.Uuid
  indicator              Indicator?            @relation("NcrIndicator", fields: [indicatorId], references: [id], onDelete: SetNull)
  indicatorMeasurementId String?               @db.Uuid
  indicatorMeasurement   IndicatorMeasurement? @relation("NcrIndicatorMeasurement", fields: [indicatorMeasurementId], references: [id], onDelete: SetNull)

  // Trazabilidad desde Riesgos
  riskId                 String?               @db.Uuid
  risk                   Risk?                 @relation("NcrRisk", fields: [riskId], references: [id], onDelete: SetNull)

  // Trazabilidad desde IPERC (Peligros SST)
  hazardId               String?               @db.Uuid
  hazard                 Hazard?               @relation("NcrHazard", fields: [hazardId], references: [id], onDelete: SetNull)

  // Trazabilidad desde Aspectos Ambientales
  environmentalAspectId   String?               @db.Uuid
  environmentalAspect     EnvironmentalAspect?  @relation("NcrEnvironmentalAspect", fields: [environmentalAspectId], references: [id], onDelete: SetNull)

  // Trazabilidad desde Simulacros
  drillId                 String?               @db.Uuid
  drill                   DrillScenario?        @relation("NcrDrill", fields: [drillId], references: [id], onDelete: SetNull)

  // Trazabilidad desde Clientes
  customerLinks          Customer[]            @relation("CustomerNCR")

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  createdById String?       @db.Uuid
  createdBy   PlatformUser? @relation("NcrCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedById String?       @db.Uuid
  updatedBy   PlatformUser? @relation("NcrUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  deletedAt DateTime? @db.Timestamptz

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([status])
  @@index([severity])
  @@index([drillId])
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GlobalRole {
  SUPER_ADMIN
}

enum TenantRole {
  TENANT_ADMIN
  TENANT_USER
}

enum PlanTier {
  BASIC
  PROFESSIONAL
  PREMIUM
}

enum FindingSeverity {
  MUST
  SHOULD
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIAL
}

enum DocumentStatus {
  DRAFT
  EFFECTIVE
  OBSOLETE
}

enum DocumentReviewStatus {
  APPROVED
  REQUIRES_UPDATE
}

enum DocumentQualityStatus {
  ADEQUATE
  IMPROVABLE
  NON_CONFORMING
}

enum NCRStatus {
  OPEN
  IN_ANALYSIS
  ACTION_PLANNED
  IN_PROGRESS
  VERIFICATION
  CLOSED
  CANCELLED
}

enum NCRSeverity {
  CRITICAL
  MAJOR
  MINOR
  OBSERVATION
}

enum NCRSource {
  INTERNAL_AUDIT
  EXTERNAL_AUDIT
  CUSTOMER_COMPLAINT
  PROCESS_DEVIATION
  SUPPLIER_ISSUE
  AI_FINDING
  OTHER
}

enum NormativeStatus {
  UPLOADING
  PROCESSING
  READY
  ERROR
  ARCHIVED
}

enum ClauseStatus {
  ACTIVE
  INACTIVE
}

enum RiskStatus {
  IDENTIFIED
  ASSESSED
  MITIGATING
  MONITORED
  CLOSED
}

enum IndicatorFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum IndicatorTrend {
  UP
  DOWN
  STABLE
}

enum IndicatorDirection {
  HIGHER_BETTER
  LOWER_BETTER
}

enum IndicatorStatus {
  ON_TARGET
  WARNING
  OFF_TARGET
  NO_DATA
}

enum SgiTrainingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SgiTrainingModality {
  PRESENCIAL
  VIRTUAL
  MIXTA
  E_LEARNING
}

enum NotificationType {
  NCR_ASSIGNED
  NCR_STATUS_CHANGED
  NCR_OVERDUE
  RISK_CRITICAL
  AUDIT_COMPLETED
  AUDIT_FAILED
  FINDING_NEW
  TRAINING_SCHEDULED
  TRAINING_REMINDER
  MEMBER_INVITED
  SYSTEM_ALERT
}

enum WebhookProvider {
  slack
  teams
  custom
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  createdById String?       @db.Uuid
  createdBy   PlatformUser? @relation("TenantCreatedBy", fields: [createdById], references: [id])

  updatedById String?       @db.Uuid
  updatedBy   PlatformUser? @relation("TenantUpdatedBy", fields: [updatedById], references: [id])

  deletedAt   DateTime? @db.Timestamptz
  storageUsed BigInt    @default(0)

  memberships   TenantMembership[]
  subscriptions TenantSubscription[]
  features      TenantFeature[]
  auditEvents   AuditEvent[]
  aiFindings          AiFinding[]
  auditRuns           AuditRun[]
  documents           Document[]
  normativeStandards  NormativeStandard[]
  departments         Department[]
  nonConformities     NonConformity[]
  risks               Risk[]
  indicators          Indicator[]
  notifications       Notification[]
  webhookConfigs      WebhookConfig[]
  sgiTrainings        SgiTraining[]
  
  // RRHH Relations
  trainings           Training[]
  employees           Employee[]
  positions           Position[]
  
  // Indicator↔Risk Links
  indicatorRiskLinks    IndicatorRiskLink[]

  // Emergency & Disaster Management
  drillScenarios    DrillScenario[]
  contingencyPlans  ContingencyPlan[]
  emergencyResources EmergencyResource[]
  
  // Customer & Survey Relations
  customers         Customer[]
  surveys           Survey[]
  improvementPlans  CustomerImprovementPlan[]
  
  // License & Billing Relations
  tenantSetup       TenantSetup?
  payments          Payment[]
  invoices          Invoice[]
  paymentPreferences PaymentPreference[]
  licenseAccessAttempts LicenseAccessAttempt[]
  licenseNotifications LicenseNotification[]
  
  // Maintenance Relations
  maintenanceAssets      MaintenanceAsset[]
  maintenanceTechnicians MaintenanceTechnician[]
  maintenancePlans       MaintenancePlan[]
  maintenanceSpareParts  MaintenanceSparePart[]
  workOrders             WorkOrder[]
  maintenanceCosts       MaintenanceCost[]

  // Process Maps
  processMaps            ProcessMap[]
}

model PlatformUser {
  id           String @id @default(uuid()) @db.Uuid
  email        String @unique
  passwordHash String

  globalRole GlobalRole?

  refreshTokenVersion Int @default(0)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  createdById String?       @db.Uuid
  createdBy   PlatformUser? @relation("UserCreatedBy", fields: [createdById], references: [id])

  updatedById String?       @db.Uuid
  updatedBy   PlatformUser? @relation("UserUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime? @db.Timestamptz

  memberships TenantMembership[]
  auditEvents AuditEvent[]       @relation("AuditActor")

  tenantsCreated Tenant[] @relation("TenantCreatedBy")
  tenantsUpdated Tenant[] @relation("TenantUpdatedBy")

  membershipsCreated TenantMembership[] @relation("MembershipCreatedBy")
  membershipsUpdated TenantMembership[] @relation("MembershipUpdatedBy")

  documentsCreated Document[] @relation("DocumentCreatedBy")
  documentsUpdated Document[] @relation("DocumentUpdatedBy")

  ncrsAssigned  NonConformity[] @relation("NcrAssignedTo")
  ncrsCreated   NonConformity[] @relation("NcrCreatedBy")
  ncrsUpdated   NonConformity[] @relation("NcrUpdatedBy")

  aiFindingsCreated AiFinding[] @relation("AiFindingCreatedBy")
  aiFindingsUpdated AiFinding[] @relation("AiFindingUpdatedBy")

  auditRunsCreated AuditRun[] @relation("AuditRunCreatedBy")

  normativesCreated      NormativeStandard[]    @relation("NormativeCreatedBy")
  normativesUpdated      NormativeStandard[]    @relation("NormativeUpdatedBy")
  clauseMappingsCreated  DocumentClauseMapping[] @relation("ClauseMappingCreatedBy")

  departmentsCreated    Department[] @relation("DepartmentCreatedBy")
  departmentsUpdated    Department[] @relation("DepartmentUpdatedBy")
  departmentMemberships DepartmentMember[] @relation("DepartmentMemberUser")
  departmentMembersCreated DepartmentMember[] @relation("DepartmentMemberCreatedBy")

  usersCreated PlatformUser[] @relation("UserCreatedBy")
  usersUpdated PlatformUser[] @relation("UserUpdatedBy")

  reviewsCreated DocumentReview[] @relation("DocumentReviewCreatedBy")

  // RRHH Relations
  employeesCreated Employee[] @relation("EmployeeCreatedBy")
  employeesUpdated Employee[] @relation("EmployeeUpdatedBy")
  positionsCreated Position[] @relation("PositionCreatedBy")
  positionsUpdated Position[] @relation("PositionUpdatedBy")
  trainingsCreated Training[] @relation("TrainingCreatedBy")
  trainingsUpdated Training[] @relation("TrainingUpdatedBy")

  // SGI Relations
  risksOwned     Risk[] @relation("RiskOwner")
  risksCreated   Risk[] @relation("RiskCreatedBy")
  risksUpdated   Risk[] @relation("RiskUpdatedBy")

  indicatorsOwned   Indicator[] @relation("IndicatorOwner")
  indicatorsCreated Indicator[] @relation("IndicatorCreatedBy")
  indicatorsUpdated Indicator[] @relation("IndicatorUpdatedBy")

  notifications Notification[] @relation("NotificationUser")

  webhooksCreated WebhookConfig[] @relation("WebhookCreatedBy")
  webhooksUpdated WebhookConfig[] @relation("WebhookUpdatedBy")

  sgiTrainingsCoordinated SgiTraining[] @relation("SgiTrainingCoordinator")
  sgiTrainingsCreated     SgiTraining[] @relation("SgiTrainingCreatedBy")
  sgiTrainingsUpdated     SgiTraining[] @relation("SgiTrainingUpdatedBy")

  sgiTrainingAttendances SgiTrainingAttendee[]

  // License & Billing Relations
  licenseAccessAttempts LicenseAccessAttempt[]
  licenseNotifications LicenseNotification[]

  // Emergency & Disaster Management
  drillsCreated         DrillScenario[]     @relation("DrillCreatedBy")
  plansCreated          ContingencyPlan[]   @relation("PlanCreatedBy")
  resourcesCreated      EmergencyResource[] @relation("ResourceCreatedBy")

  // Two-Factor Authentication
  twoFactorAuth           TwoFactorAuth?
  twoFactorSessions       TwoFactorSession[]
  twoFactorAuthsCreated   TwoFactorAuth[]         @relation("2FACreatedBy")

  // Document Versions
  documentVersionsCreated DocumentVersion[]       @relation("DocumentVersionCreatedBy")
  
  // Customer & Survey Relations
  customersCreated Customer[] @relation("CustomerCreatedBy")
  customersUpdated Customer[] @relation("CustomerUpdatedBy")
  surveysCreated   Survey[]   @relation("SurveyCreatedBy")
  surveysUpdated   Survey[]   @relation("SurveyUpdatedBy")
  
  // Invoice Relations
  invoicesCreated  Invoice[] @relation("InvoiceCreatedBy")
  
  // Password History Relations
  passwordHistory PasswordHistory[]
  passwordChangesMade PasswordHistory[] @relation("PasswordChangedBy")

  // Process Maps
  processMapsCreated ProcessMap[] @relation("ProcessMapCreatedBy")
}

model TenantMembership {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String       @db.Uuid
  user   PlatformUser @relation(fields: [userId], references: [id])

  role   TenantRole
  status MembershipStatus @default(ACTIVE)

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  createdById String?       @db.Uuid
  createdBy   PlatformUser? @relation("MembershipCreatedBy", fields: [createdById], references: [id])

  updatedById String?       @db.Uuid
  updatedBy   PlatformUser? @relation("MembershipUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime? @db.Timestamptz

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId])
}

// ──────────────────────────────────────────────────────────────
// Módulos SGI (Riesgos / Indicadores / Notificaciones / Integraciones)
// ──────────────────────────────────────────────────────────────

model Risk {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code        String
  title       String
  description String
  category    String
  process     String?
  standard    String?

  // Fechas importantes para gestión de riesgos
  identificationDate DateTime  @default(now()) @db.Timestamptz // Fecha cuando se identificó el riesgo
  reviewDate         DateTime? @db.Timestamptz // Fecha de última revisión/evaluación
  closureDate        DateTime? @db.Timestamptz // Fecha de cierre del riesgo

  probability Int
  impact      Int
  riskLevel   Int

  inherentProbability Int? // Probabilidad inherente (antes de controles)
  inherentImpact      Int? // Impacto inherente (antes de controles)

  residualProb   Int?
  residualImpact Int?
  residualLevel  Int?

  treatmentPlan String?
  controls      String?

  status  RiskStatus @default(IDENTIFIED)

  // Campos específicos por norma ISO 14001, 9001, 45001, IATF 16949
  requirement          String?         // Requisito normativo específico (ej: "ISO 14001:2015 - Cláusula 6.1.2")
  aspectType           RiskAspectType? // Tipo de aspecto (Ambiental, Calidad, Seguridad, etc.)
  hazard               String?         // Peligro identificado (ISO 45001)
  environmentalAspect  String?         // Aspecto ambiental (ISO 14001)
  legalRequirement     Boolean? @default(false) // Indica si hay requisito legal
  legalReference       String?         // Referencia legal específica
  riskSource           String?         // Origen del riesgo (interno/externo)
  strategy             RiskStrategy?   // Estrategia de tratamiento (ISO 31000)
  responsible          String?         // Nombre del responsable
  effectiveness        Int?            // Eficacia de controles (0-100%)

  ownerId String?       @db.Uuid
  owner   PlatformUser? @relation("RiskOwner", fields: [ownerId], references: [id])

  // Relations
  indicatorLinks        IndicatorRiskLink[]
  ncrs                  NonConformity[] @relation("NcrRisk")

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  createdById String?       @db.Uuid
  createdBy   PlatformUser? @relation("RiskCreatedBy", fields: [createdById], references: [id])

  updatedById String?       @db.Uuid
  updatedBy   PlatformUser? @relation("RiskUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime? @db.Timestamptz

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([status])
  @@index([riskLevel])
  @@index([identificationDate])
  @@index([closureDate])
  @@index([aspectType])
}

// Tipo de aspecto para diferentes normas ISO
enum RiskAspectType {
  AMBIENTAL       // ISO 14001
  CALIDAD         // ISO 9001
  SEGURIDAD       // ISO 45001
  LEGAL           // Requisitos legales
  IATF            // IATF 16949 (automotriz)
  TECNOLOGICO
  FINANCIERO
  REPUTACIONAL
}

// Estrategia de tratamiento según ISO 31000
enum RiskStrategy {
  EVITAR
  MITIGAR
  TRANSFERIR
  ACEPTAR
}

model Indicator {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code        String
  name        String
  description String?
  category    String
  process     String?
  standard    String?

  currentValue Float?
  targetValue  Float?
  minValue     Float?
  maxValue     Float?
  unit         String

  direction IndicatorDirection @default(HIGHER_BETTER)

  // Umbral de alerta (amarillo). Si no se define, se usa targetValue como límite.
  warningValue  Float?
  criticalValue Float?

  status IndicatorStatus @default(NO_DATA)

  lastMeasuredAt DateTime? @db.Timestamptz
  nextDueAt      DateTime? @db.Timestamptz

  offTargetStreak     Int @default(0)
  ncrTriggerStreak    Int @default(2)

  frequency IndicatorFrequency
  trend     IndicatorTrend @default(STABLE)
  isActive  Boolean        @default(true)

  ownerId String?       @db.Uuid
  owner   PlatformUser? @relation("IndicatorOwner", fields: [ownerId], references: [id])

  measurements IndicatorMeasurement[]
  ncrs                 NonConformity[] @relation("NcrIndicator")
  riskLinks            IndicatorRiskLink[]

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  createdById String?       @db.Uuid
  createdBy   PlatformUser? @relation("IndicatorCreatedBy", fields: [createdById], references: [id])

  updatedById String?       @db.Uuid
  updatedBy   PlatformUser? @relation("IndicatorUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime? @db.Timestamptz

  @@unique([tenantId, code])
  @@index([tenantId])
}

model IndicatorMeasurement {
  id          String @id @default(uuid()) @db.Uuid
  indicatorId String @db.Uuid
  indicator   Indicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)

  value      Float
  period     String
  notes      String?
  measuredAt DateTime @default(now()) @db.Timestamptz

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  ncrs NonConformity[] @relation("NcrIndicatorMeasurement")

  @@index([indicatorId])
  @@unique([indicatorId, period])
}

model IndicatorRiskLink {
  id          String @id @default(uuid()) @db.Uuid
  tenantId    String @db.Uuid
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  indicatorId String @db.Uuid
  indicator   Indicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)

  riskId String @db.Uuid
  risk   Risk   @relation(fields: [riskId], references: [id], onDelete: Cascade)

  // Cuánto ajusta la probabilidad sugerida (NP) cuando el indicador está fuera de meta
  offTargetProbDelta Int @default(1)
  warningProbDelta   Int @default(1)
  minSuggestedProb   Int? // opcional (ej: al menos 4 si hay NCR abierta)

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@unique([tenantId, indicatorId, riskId])
  @@index([tenantId])
  @@index([indicatorId])
  @@index([riskId])
}

model Notification {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String       @db.Uuid
  user   PlatformUser @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)

  type      NotificationType
  title     String
  message   String
  link      String?
  entityType String?
  entityId   String?

  isRead Boolean  @default(false)
  readAt DateTime? @db.Timestamptz

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  deletedAt DateTime? @db.Timestamptz

  @@index([tenantId])
  @@index([userId])
  @@index([isRead])
}

model WebhookConfig {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  provider WebhookProvider
  name     String
  url      String
  isActive Boolean @default(true)
  events   String[]

  lastSentAt DateTime? @db.Timestamptz
  lastError  String?
  totalSent  Int @default(0)
  totalErrors Int @default(0)

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  createdById String?       @db.Uuid
  createdBy   PlatformUser? @relation("WebhookCreatedBy", fields: [createdById], references: [id])

  updatedById String?       @db.Uuid
  updatedBy   PlatformUser? @relation("WebhookUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime? @db.Timestamptz

  @@index([tenantId])
  @@index([isActive])
}

model SgiTraining {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code        String
  title       String
  description String?
  category    String
  modality    SgiTrainingModality
  instructor  String?
  instructorType String? // INTERNAL | EXTERNAL
  location    String?

  // ISO 9001:2015 - 7.2 Competencia
  objectives          String? // Objetivos de aprendizaje
  contentProgram      String? // Contenido programático
  methodologyDetails  String? // Metodología detallada
  evaluationCriteria  String? // Criterios de evaluación
  
  // Vinculación con Competencias (brechas identificadas)
  competencyId String?     @db.Uuid
  competency   Competency? @relation(fields: [competencyId], references: [id])
  gapLevel     Int?        // Nivel de brecha que cubre (1-5)
  
  // Control de documentación ISO
  materialUrl     String? // Material didáctico
  certificateTemplate String? // Template de certificado
  
  durationHours Float
  scheduledDate DateTime? @db.Timestamptz
  // Gestión del ciclo de vida de la capacitación
  completedDate DateTime? @db.Timestamptz
  completedById String? @db.Uuid // Quién marcó como completada
  
  // Reprogramación
  rescheduledDate DateTime? @db.Timestamptz // Nueva fecha programada
  rescheduleReason String? // Motivo de reprogramación
  rescheduledById String? @db.Uuid // Quién reprogramó
  
  // Cancelación
  cancelledAt DateTime? @db.Timestamptz
  cancellationReason String? // Motivo de cancelación
  cancelledById String? @db.Uuid // Quién canceló
  
  status        SgiTrainingStatus @default(SCHEDULED)
  standard      String?

  expectedParticipants Int @default(0)

  coordinatorId String?       @db.Uuid
  coordinator   PlatformUser? @relation("SgiTrainingCoordinator", fields: [coordinatorId], references: [id])

  attendees SgiTrainingAttendee[]
  
  // Evaluaciones ISO
  satisfactionEvaluations TrainingSatisfaction[]
  effectivenessEvaluations TrainingEffectiveness[]

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  createdById String?       @db.Uuid
  createdBy   PlatformUser? @relation("SgiTrainingCreatedBy", fields: [createdById], references: [id])

  updatedById String?       @db.Uuid
  updatedBy   PlatformUser? @relation("SgiTrainingUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime? @db.Timestamptz

  @@unique([tenantId, code])
  @@index([tenantId])
}

model SgiTrainingAttendee {
  id         String @id @default(uuid()) @db.Uuid
  trainingId String @db.Uuid
  training   SgiTraining @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  // Soporte para empleados de RRHH (principal) o usuarios del sistema
  employeeId String? @db.Uuid
  
  userId String? @db.Uuid
  user   PlatformUser? @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ISO 9001:2015 - Control de asistencia
  attended Boolean @default(false)
  signatureData String?
  attendanceNotes String?
  attendanceMarkedAt DateTime? @db.Timestamptz
  attendanceMarkedById String? @db.Uuid

  // Evaluación de aprendizaje (Quiz)
  quizScore Int?
  quizPassed Boolean @default(false)
  quizCompletedAt DateTime? @db.Timestamptz

  createdAt DateTime @default(now()) @db.Timestamptz

  @@unique([trainingId, employeeId])
  @@index([trainingId])
  @@index([employeeId])
  @@index([userId])
}

// ISO 9001:2015 - Evaluación de satisfacción post-capacitación
model TrainingSatisfaction {
  id         String @id @default(uuid()) @db.Uuid
  trainingId String @db.Uuid
  training   SgiTraining @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  attendeeId String?       @db.Uuid
  
  // Evaluación Likert 1-5
  contentRelevance   Int? // Relevancia del contenido
  instructorQuality  Int? // Calidad del instructor
  materialsQuality   Int? // Calidad de materiales
  methodologyQuality Int? // Calidad de metodología
  overallSatisfaction Int? // Satisfacción general
  
  comments String? // Comentarios adicionales
  
  evaluatedAt DateTime @default(now()) @db.Timestamptz
  
  @@index([trainingId])
}

// ISO 9001:2015 - Evaluación de efectividad (30-90 días post)
model TrainingEffectiveness {
  id         String @id @default(uuid()) @db.Uuid
  trainingId String @db.Uuid
  training   SgiTraining @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  attendeeId String? @db.Uuid
  evaluatorId String? @db.Uuid // Quién evalúa (supervisor/RRHH)
  
  // Indicadores de efectividad
  knowledgeApplication Int? // Aplicación de conocimientos (1-5)
  performanceImprovement Int? // Mejora en desempeño (1-5)
  competencyGapReduction Int? // Reducción de brecha (1-5)
  
  // Evidencias
  evidenceDescription String? // Descripción de evidencias
  evidenceDocuments String[] // URLs de documentos evidencia
  
  evaluationDate DateTime? @db.Timestamptz // Fecha de evaluación
  daysAfterTraining Int? // Días después de la capacitación
  
  approved Boolean @default(false) // Aprobada por supervisor
  approvedById String? @db.Uuid
  approvedAt DateTime? @db.Timestamptz
  
  createdAt DateTime @default(now()) @db.Timestamptz
  
  @@index([trainingId])
  @@index([attendeeId])
}

model Department {
  id        String @id @default(uuid()) @db.Uuid
  tenantId  String @db.Uuid
  tenant    Tenant @relation(fields: [tenantId], references: [id])

  name        String
  description String?
  color       String  @default("#3B82F6") // Default blue

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  createdById String?       @db.Uuid
  createdBy   PlatformUser? @relation("DepartmentCreatedBy", fields: [createdById], references: [id])

  updatedById String?       @db.Uuid
  updatedBy   PlatformUser? @relation("DepartmentUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime? @db.Timestamptz

  documents Document[]
  members   DepartmentMember[]
  
  // RRHH Relations
  employees Employee[] @relation("EmployeeDepartment")

  @@unique([tenantId, name])
  @@index([tenantId])
}

model DepartmentMember {
  id           String @id @default(uuid()) @db.Uuid
  departmentId String @db.Uuid
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  userId String       @db.Uuid
  user   PlatformUser @relation("DepartmentMemberUser", fields: [userId], references: [id], onDelete: Cascade)

  role      String @default("MEMBER") // MANAGER, MEMBER
  joinedAt  DateTime @default(now()) @db.Timestamptz

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  createdById String?       @db.Uuid
  createdBy   PlatformUser? @relation("DepartmentMemberCreatedBy", fields: [createdById], references: [id])

  deletedAt DateTime? @db.Timestamptz

  @@unique([departmentId, userId])
  @@index([departmentId])
  @@index([userId])
}

model Document {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  departmentId String?    @db.Uuid
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  normativeId String?            @db.Uuid
  normative   NormativeStandard? @relation(fields: [normativeId], references: [id], onDelete: SetNull)

  customerId String? @db.Uuid
  customer   Customer? @relation("CustomerDocuments", fields: [customerId], references: [id], onDelete: SetNull)

  title        String
  type         String
  content      String?        @db.Text
  filePath     String?
  standardTags Json?
  status       DocumentStatus @default(DRAFT)
  version      Int            @default(1)

  // Control documental ISO
  process       String?
  ownerId       String?       @db.Uuid
  owner         Employee?     @relation("DocumentOwner", fields: [ownerId], references: [id])
  reviewDate        DateTime? @db.Timestamptz
  nextReviewDate    DateTime? @db.Timestamptz
  reviewStatus      DocumentReviewStatus? @default(APPROVED)
  documentQualityStatus DocumentQualityStatus? @default(ADEQUATE)

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  createdById String?       @db.Uuid
  createdBy   PlatformUser? @relation("DocumentCreatedBy", fields: [createdById], references: [id])

  updatedById String?       @db.Uuid
  updatedBy   PlatformUser? @relation("DocumentUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime? @db.Timestamptz

  clauseMappings DocumentClauseMapping[]
  aiFindings     AiFinding[]
  auditRuns      AuditRun[]
  versions       DocumentVersion[]
  reviews        DocumentReview[]

  @@index([tenantId])
  @@index([departmentId])
  @@index([normativeId])
  @@index([customerId])
  @@index([status])
}

model DocumentVersion {
  id           String   @id @default(uuid()) @db.Uuid
  documentId   String   @db.Uuid
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  
  version      Int
  filePath     String
  originalName String?
  fileSize     Int?
  
  createdById  String?       @db.Uuid
  createdBy    PlatformUser? @relation("DocumentVersionCreatedBy", fields: [createdById], references: [id])
  
  createdAt    DateTime @default(now()) @db.Timestamptz
  
  @@index([documentId])
}

model DocumentReview {
  id         String   @id @default(uuid()) @db.Uuid
  documentId String   @db.Uuid
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  reviewedAt DateTime @default(now()) @db.Timestamptz
  result     DocumentReviewStatus
  comments   String? @db.Text

  reviewedById String?       @db.Uuid
  reviewedBy   PlatformUser? @relation("DocumentReviewCreatedBy", fields: [reviewedById], references: [id])

  createdAt DateTime @default(now()) @db.Timestamptz

  @@index([documentId])
}

model Plan {
  id   String   @id @default(uuid()) @db.Uuid
  tier PlanTier @unique
  name String

  // Definición de módulos/habilitaciones y límites a nivel plan
  features Json
  limits   Json?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  subscriptions TenantSubscription[]
  payments      Payment[]
}

model TenantSubscription {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  planId String @db.Uuid
  plan   Plan   @relation(fields: [planId], references: [id])

  status    SubscriptionStatus @default(TRIAL)
  startedAt DateTime           @default(now()) @db.Timestamptz
  endsAt    DateTime?          @db.Timestamptz
  price     Decimal?           @db.Decimal(10,2) // Precio personalizado de la suscripción

  // Integración futura con proveedor (Stripe/etc.)
  provider    String?
  providerRef String?

  // Relaciones
  payments Payment[]

  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  deletedAt DateTime? @db.Timestamptz

  @@index([tenantId])
}

model TenantFeature {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  key     String
  enabled Boolean @default(true)
  config  Json?

  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  deletedAt DateTime? @db.Timestamptz

  @@unique([tenantId, key])
  @@index([tenantId])
}

model AuditEvent {
  id       String  @id @default(uuid()) @db.Uuid
  tenantId String? @db.Uuid
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  actorUserId String?       @db.Uuid
  actorUser   PlatformUser? @relation("AuditActor", fields: [actorUserId], references: [id])

  action     String
  entityType String
  entityId   String?
  metadata   Json?

  createdAt DateTime @default(now()) @db.Timestamptz
}

model AiFinding {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  severity    FindingSeverity
  standard    String
  clause      String
  title       String
  description String
  relatedRefs Json?

  // Motor de IA Auditora
  auditRunId String?   @db.Uuid
  auditRun   AuditRun? @relation(fields: [auditRunId], references: [id], onDelete: SetNull)

  auditType String? // "document_vs_norma", "tenant_audit", "chat"

  documentId String?   @db.Uuid
  document   Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  normativeId String?            @db.Uuid
  normative   NormativeStandard? @relation(fields: [normativeId], references: [id], onDelete: SetNull)

  clauseId String?          @db.Uuid
  clauseRef NormativeClause? @relation(fields: [clauseId], references: [id], onDelete: SetNull)

  confidence       Float? // Score 0-1 de la IA
  evidence         String? // Evidencia extraída del documento
  suggestedActions Json? // Array de acciones correctivas

  status    String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  createdById String?       @db.Uuid
  createdBy   PlatformUser? @relation("AiFindingCreatedBy", fields: [createdById], references: [id])

  updatedById String?       @db.Uuid
  updatedBy   PlatformUser? @relation("AiFindingUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime? @db.Timestamptz

  @@index([tenantId])
  @@index([auditRunId])
  @@index([documentId])
  @@index([normativeId])
  @@index([status])
}

model AuditRun {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type   String // "document_vs_norma", "tenant_audit"
  status String @default("QUEUED") // QUEUED, RUNNING, COMPLETED, FAILED

  // Para auditorías doc vs norma
  documentId  String?            @db.Uuid
  document    Document?          @relation(fields: [documentId], references: [id], onDelete: SetNull)
  normativeId String?            @db.Uuid
  normative   NormativeStandard? @relation(fields: [normativeId], references: [id], onDelete: SetNull)

  // Resultados
  totalClauses   Int @default(0)
  coveredClauses Int @default(0)
  missingClauses Int @default(0)
  findingsCount  Int @default(0)

  // Job tracking
  jobId String?
  error String?

  startedAt   DateTime  @default(now()) @db.Timestamptz
  completedAt DateTime? @db.Timestamptz

  createdById String?       @db.Uuid
  createdBy   PlatformUser? @relation("AuditRunCreatedBy", fields: [createdById], references: [id])

  deletedAt DateTime? @db.Timestamptz

  // Relaciones
  findings AiFinding[]

  @@index([tenantId])
  @@index([status])
}

// ──────────────────────────────────────────────────────────────
// Módulo de Cumplimiento Normativo (multinorma)
// ──────────────────────────────────────────────────────────────

model NormativeStandard {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Metadatos de la norma
  name        String  // ej: "ISO 9001:2015"
  code        String  // ej: "ISO9001-2015" (unique por tenant)
  version     String  // ej: "2015"
  description String?

  // Archivo PDF subido
  originalFileName String
  fileSize         Int      // bytes
  filePath         String   // storage key (local path o S3 key)
  fileHash         String   // SHA-256 para deduplicación

  // Estado de procesamiento
  status          NormativeStatus @default(UPLOADING)
  processingJobId String?         // BullMQ job ID
  errorMessage    String?

  // Resultado del procesamiento
  totalClauses Int       @default(0)
  extractedAt  DateTime? @db.Timestamptz

  // Auditoría
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  createdById String?       @db.Uuid
  createdBy   PlatformUser? @relation("NormativeCreatedBy", fields: [createdById], references: [id])

  updatedById String?       @db.Uuid
  updatedBy   PlatformUser? @relation("NormativeUpdatedBy", fields: [updatedById], references: [id])

  deletedAt DateTime? @db.Timestamptz

  // Relaciones
  clauses    NormativeClause[]
  aiFindings AiFinding[]
  auditRuns  AuditRun[]
  documents  Document[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([status])
}

model NormativeClause {
  id          String            @id @default(uuid()) @db.Uuid
  normativeId String            @db.Uuid
  normative   NormativeStandard @relation(fields: [normativeId], references: [id], onDelete: Cascade)

  // Identificación de la cláusula
  clauseNumber String // ej: "4.1", "4.1.1", "A.1"
  title        String
  content      String // Texto completo de la cláusula

  // Jerarquía
  parentClauseId String?           @db.Uuid
  parentClause   NormativeClause?  @relation("ClauseHierarchy", fields: [parentClauseId], references: [id], onDelete: SetNull)
  childClauses   NormativeClause[] @relation("ClauseHierarchy")

  level           Int  // Profundidad jerárquica (0 = sección principal)
  extractionOrder Int  // Posición en el documento
  pageNumber      Int? // Página del PDF original

  // Metadatos de búsqueda
  keywords Json? // Array JSON de palabras clave

  status ClauseStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  deletedAt DateTime? @db.Timestamptz

  // Relaciones
  documentMappings DocumentClauseMapping[]
  aiFindings       AiFinding[]
  clauseEvidences  ClauseEvidence[]

  @@unique([normativeId, clauseNumber])
  @@index([normativeId])
  @@index([clauseNumber])
}

model DocumentClauseMapping {
  id String @id @default(uuid()) @db.Uuid

  documentId String   @db.Uuid
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  clauseId String          @db.Uuid
  clause   NormativeClause @relation(fields: [clauseId], references: [id], onDelete: Cascade)

  // Tipo de relación entre documento y cláusula
  complianceType String  // "CUMPLE", "REFERENCIA", "IMPLEMENTA", "NO_APLICA"
  notes          String? // Notas de evidencia

  // Auditoría
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  createdById String?       @db.Uuid
  createdBy   PlatformUser? @relation("ClauseMappingCreatedBy", fields: [createdById], references: [id])

  deletedAt DateTime? @db.Timestamptz

  @@unique([documentId, clauseId])
  @@index([documentId])
  @@index([clauseId])
}

model ClauseEvidence {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid

  clauseId      String    @db.Uuid
  clause        NormativeClause @relation(fields: [clauseId], references: [id], onDelete: Cascade)

  type          String    // DOCUMENT, MODULE, INDICATOR, ACTION
  referenceId   String?   @db.Uuid // ID del registro en el módulo referenciado
  referenceType String?   // ej: "suppliers", "customers", "kpi", "ncr", "audit", "capa"
  description   String?
  isActive      Boolean   @default(true)

  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz

  @@index([clauseId])
  @@index([tenantId])
  @@map("clause_evidences")
}

// ──────────────────────────────────────────────────────────────
// Two-Factor Authentication (2FA)
// ──────────────────────────────────────────────────────────────

model TwoFactorAuth {
  id String @id @default(uuid()) @db.Uuid

  userId String       @db.Uuid
  user   PlatformUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  // TOTP secret (encrypted in production)
  secret String @db.Text

  // QR code URL (generated from secret)
  qrCodeUrl String? @db.Text

  // Status flags
  isEnabled    Boolean  @default(false)      // Is 2FA active for this user?
  isConfirmed  Boolean  @default(false)      // Has user confirmed 2FA setup?
  createdAt    DateTime @default(now()) @db.Timestamptz
  enabledAt    DateTime? @db.Timestamptz     // When 2FA was enabled
  disabledAt   DateTime? @db.Timestamptz     // When 2FA was disabled

  // Recovery codes
  recoveryCodes TwoFactorRecoveryCode[]

  // Audit trail
  createdById String?       @db.Uuid
  createdBy   PlatformUser? @relation("2FACreatedBy", fields: [createdById], references: [id])

  @@unique([userId])
  @@index([userId])
  @@index([isEnabled])
}

model TwoFactorRecoveryCode {
  id String @id @default(uuid()) @db.Uuid

  twoFactorAuthId String         @db.Uuid
  twoFactorAuth   TwoFactorAuth  @relation(fields: [twoFactorAuthId], references: [id], onDelete: Cascade)

  // Recovery code (hashed)
  code String @unique

  // Has this code been used?
  used       Boolean   @default(false)
  usedAt     DateTime? @db.Timestamptz
  usedBy     String?   @db.Text // IP address or user agent

  createdAt DateTime @default(now()) @db.Timestamptz

  @@index([twoFactorAuthId])
  @@index([used])
}

model TwoFactorSession {
  id String @id @default(uuid()) @db.Uuid

  userId String       @db.Uuid
  user   PlatformUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Temporary session state during 2FA verification
  sessionToken String @unique        // Token that grants temporary access
  verified     Boolean @default(false) // Has user verified TOTP?

  // Context
  ipAddress    String?
  userAgent    String?

  // Expiration
  expiresAt DateTime @db.Timestamptz

  createdAt DateTime @default(now()) @db.Timestamptz

  @@index([userId])
  @@index([verified])
  @@index([expiresAt])
}

// ──────────────────────────────────────────────────────────────
// Módulo de Recursos Humanos (RRHH)
// ──────────────────────────────────────────────────────────────

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

enum ContractType {
  PERMANENT
  TEMPORARY
  CONTRACTOR
  INTERN
  PART_TIME
}

enum TrainingType {
  INTERNAL
  EXTERNAL
  ONLINE
  WORKSHOP
  CERTIFICATION
}

enum TrainingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EXPIRED
}

model Employee {
  id           String @id @default(uuid()) @db.Uuid
  tenantId     String @db.Uuid
  tenant       Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  departmentId String? @db.Uuid
  department   Department? @relation("EmployeeDepartment", fields: [departmentId], references: [id])
  
  positionId   String? @db.Uuid
  position     Position? @relation(fields: [positionId], references: [id])
  
  supervisorId String? @db.Uuid
  supervisor   Employee? @relation("EmployeeHierarchy", fields: [supervisorId], references: [id])
  subordinates  Employee[] @relation("EmployeeHierarchy")

  reportsToPositionId String? @db.Uuid
  reportsToPosition   Position? @relation("EmployeeReportsToPosition", fields: [reportsToPositionId], references: [id])
  
  // Personal Data
  firstName     String
  lastName      String
  dni           String
  birthDate     DateTime @db.Timestamptz
  address       String
  phone         String
  email         String
  cuil          String?
  
  // Work Data
  hireDate      DateTime @db.Timestamptz
  contractType  ContractType
  location      String?
  status        EmployeeStatus @default(ACTIVE)
  
  // Profile
  profilePhoto  String?
  notes         String?
  
  // System Access (1:1 relationship)
  user          User?
  
  // Competencies
  employeeCompetencies EmployeeCompetency[]
  
  // Trainings
  trainingAssignments TrainingAssignment[]

  // Documents
  documentsOwned Document[] @relation("DocumentOwner")

  // Environmental (ISO 14001)
  environmentalAspectsResponsible EnvironmentalAspect[] @relation("EnvironmentalAspectResponsible")
  environmentalActionsAssigned    EnvironmentalAction[] @relation("EnvironmentalActionAssigned")
  environmentalReviewsBy          EnvironmentalReview[] @relation("EnvironmentalReviewBy")

  // Emergency (ISO 14001/45001)
  drillsResponsible               DrillScenario[]         @relation("DrillResponsible")
  drillParticipants               DrillParticipant[]      @relation("DrillParticipantEmployee")
  drillActionsAssigned            DrillAction[]           @relation("DrillActionResponsible")
  contingencyPlansResponsible     ContingencyPlan[]       @relation("ContingencyPlanResponsible")
  emergencyResourcesResponsible   EmergencyResource[]     @relation("EmergencyResourceResponsible")

  // Audit
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz
  
  createdById String? @db.Uuid
  createdBy   PlatformUser? @relation("EmployeeCreatedBy", fields: [createdById], references: [id])
  
  updatedById String? @db.Uuid
  updatedBy   PlatformUser? @relation("EmployeeUpdatedBy", fields: [updatedById], references: [id])
  
  deletedAt DateTime? @db.Timestamptz
  
  @@unique([tenantId, dni])
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([departmentId])
  @@index([positionId])
  @@index([supervisorId])
  @@index([reportsToPositionId])
  @@index([status])
}

model User {
  id        String @id @default(uuid()) @db.Uuid
  employeeId String @unique @db.Uuid
  employee  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  email     String @unique
  password  String // Hashed password
  status    String @default("ACTIVE") // ACTIVE, INACTIVE, LOCKED
  
  // Auth tracking
  lastLoginAt DateTime? @db.Timestamptz
  loginAttempts Int @default(0)
  lockedUntil DateTime? @db.Timestamptz
  
  // Roles
  roles     UserRole[]
  
  // Granular permissions per module (JSON: { "dashboard": "view", "documents": "edit", ... })
  permissions Json?
  
  // Audit
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz
  
  @@index([email])
  @@index([status])
}

model Role {
  id          String @id @default(uuid()) @db.Uuid
  name        String @unique
  description String?
  permissions String[] // JSON array of permissions
  status      String @default("ACTIVE") // ACTIVE, INACTIVE
  
  // Relations
  users       UserRole[]
  
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz
  
  @@map("roles")
}

model UserRole {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  roleId String @db.Uuid
  
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  @@unique([userId, roleId])
  @@map("user_roles")
}

model Position {
  id          String @id @default(uuid()) @db.Uuid
  tenantId    String @db.Uuid
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name        String
  code        String?
  category    String?
  level       String?  // Seniority level
  
  // Profile Definition
  objective   String?
  responsibilities String[] // JSON array
  tasks       String[] // JSON array
  requirements String[] // JSON array
  
  // KPIs and Risks
  kpis        String[] // JSON array
  risks       String[] // JSON array (ISO 39001 risks)
  
  // Relations
  employees   Employee[]
  reportsToEmployees Employee[] @relation("EmployeeReportsToPosition")
  positionCompetencies PositionCompetency[]
  
  // Audit
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz
  
  createdById String? @db.Uuid
  createdBy   PlatformUser? @relation("PositionCreatedBy", fields: [createdById], references: [id])
  
  updatedById String? @db.Uuid
  updatedBy   PlatformUser? @relation("PositionUpdatedBy", fields: [updatedById], references: [id])
  
  deletedAt DateTime? @db.Timestamptz
  
  @@unique([tenantId, name])
  @@index([tenantId])
}

model Competency {
  id          String @id @default(uuid()) @db.Uuid
  name        String @unique
  category    String
  description String?
  levels      String[] // JSON array of level descriptions
  
  // Relations
  positionCompetencies PositionCompetency[]
  employeeCompetencies EmployeeCompetency[]
  trainings SgiTraining[] // Capacitaciones que cubren esta competencia
  
  // Audit
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz
  
  @@map("competencies")
}

model PositionCompetency {
  id           String @id @default(uuid()) @db.Uuid
  positionId   String @db.Uuid
  competencyId String @db.Uuid
  requiredLevel Int    // 1-5 scale
  
  position     Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  competency   Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  
  @@unique([positionId, competencyId])
  @@map("position_competencies")
}

model EmployeeCompetency {
  id           String @id @default(uuid()) @db.Uuid
  employeeId   String @db.Uuid
  competencyId String @db.Uuid
  currentLevel Int    // 1-5 scale
  assessedBy   String?
  assessedAt   DateTime? @db.Timestamptz
  notes        String?
  
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  competency   Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  
  @@unique([employeeId, competencyId])
  @@map("employee_competencies")
}

model Training {
  id          String @id @default(uuid()) @db.Uuid
  tenantId    String @db.Uuid
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  title       String
  description String?
  type        TrainingType
  duration    Int?     // in hours
  cost        Decimal? @db.Decimal(10, 2)
  
  // Competency Link
  competencyIds String[] // JSON array of competency IDs
  
  // Relations
  assignments TrainingAssignment[]
  
  // Audit
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz
  
  createdById String? @db.Uuid
  createdBy   PlatformUser? @relation("TrainingCreatedBy", fields: [createdById], references: [id])
  
  updatedById String? @db.Uuid
  updatedBy   PlatformUser? @relation("TrainingUpdatedBy", fields: [updatedById], references: [id])
  
  deletedAt DateTime? @db.Timestamptz
  
  @@index([tenantId])
}

model TrainingAssignment {
  id          String @id @default(uuid()) @db.Uuid
  trainingId  String @db.Uuid
  training    Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  
  employeeId  String @db.Uuid
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  // Assignment tracking
  status      TrainingStatus @default(PENDING)
  assignedAt  DateTime @default(now()) @db.Timestamptz
  completedAt DateTime? @db.Timestamptz
  dueDate     DateTime? @db.Timestamptz
  score       Decimal? @db.Decimal(5, 2)
  certificate String?
  
  @@unique([trainingId, employeeId])
  @@map("training_assignments")
}

// ==================== ISO AUDIT MODULE ====================

enum AuditType {
  INTERNAL
  EXTERNAL
  SUPPLIER
  CUSTOMER
  CERTIFICATION
  RECERTIFICATION
  SURVEILLANCE
}

enum AuditStatus {
  DRAFT
  PLANNED
  SCHEDULED
  IN_PROGRESS
  PENDING_REPORT
  COMPLETED
  CLOSED
  CANCELLED
}

enum ProgramStatus {
  ACTIVE
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum FindingType {
  NON_CONFORMITY
  OPPORTUNITY
  COMMENDATION
}

enum AuditFindingSeverity {
  CRITICAL
  MAJOR
  MINOR
  TRIVIAL
}

enum FindingStatus {
  OPEN
  IN_ANALYSIS
  IN_ACTION
  PENDING_VALIDATION
  CLOSED
  REOPENED
}

enum ChecklistResponseStatus {
  COMPLIES
  DOES_NOT_COMPLY
  NOT_APPLICABLE
}

enum ActionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  VALIDATED
  REJECTED
}

enum AuditorType {
  INTERNAL
  EXTERNAL
}

enum IsoStandard {
  ISO_9001
  ISO_14001
  ISO_45001
  ISO_39001
  IATF_16949
  ISO_27001
  ISO_50001
  CUSTOM
}

// Company Settings (Logo and branding)
model CompanySettings {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid @unique
  
  // Company Info
  companyName String
  legalName   String?
  taxId       String?
  address     String?
  phone       String?
  email       String?
  website     String?
  
  // Logo and Branding
  logoUrl     String?  // URL to logo image (stored in S3 or local)
  logoDarkUrl String?  // Dark mode logo variant
  faviconUrl  String?
  
  // Report Settings
  headerText  String?  // Custom text for report headers
  footerText  String?  // Custom text for report footers
  primaryColor String? @default("#2563eb") // Brand color
  
  // Metadata
  updatedAt   DateTime @updatedAt @db.Timestamptz
  updatedById String   @db.Uuid
  
  @@index([tenantId])
  @@map("company_settings")
}

// Audit Program (Annual Program)
model AuditProgram {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  
  year        Int
  name        String
  description String?
  status      ProgramStatus @default(ACTIVE)
  
  // Metadata
  createdById String   @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz
  deletedAt   DateTime? @db.Timestamptz
  
  @@unique([tenantId, year])
  @@index([tenantId])
  @@index([status])
  @@map("audit_programs")
}

// Individual Audit
model Audit {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  programId       String   @db.Uuid
  
  code            String
  title           String
  description     String?
  type            AuditType
  status          AuditStatus @default(DRAFT)
  
  // Planning
  plannedStartDate DateTime? @db.Timestamptz
  plannedEndDate   DateTime? @db.Timestamptz
  actualStartDate  DateTime? @db.Timestamptz
  actualEndDate    DateTime? @db.Timestamptz
  duration         Int?     // in hours
  
  // Audit Team
  leadAuditorId   String   @db.Uuid
  
  // Scope
  area            String
  process         String?
  isoStandard     IsoStandard[]
  scope           String?
  objective       String?
  interviewees    String?  @db.Text
  
  // Metadata
  createdById     String   @db.Uuid
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz
  deletedAt       DateTime? @db.Timestamptz
  
  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([programId])
  @@index([status])
  @@index([plannedStartDate])
  @@map("audits")
}

// Auditor Management
model Auditor {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  employeeId      String?  @db.Uuid
  
  type            AuditorType
  name            String
  email           String
  phone           String?
  company         String?
  
  // Competencies
  normativeCompetencies IsoStandard[]
  isActive        Boolean  @default(true)
  
  // Relations
  documents       AuditorDocument[]
  
  // Metadata
  createdById     String   @db.Uuid
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz
  deletedAt       DateTime? @db.Timestamptz
  
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([employeeId])
  @@map("auditors")
}

// Auditor Documents (Certificates, Diplomas)
model AuditorDocument {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  auditorId   String   @db.Uuid
  auditor     Auditor  @relation(fields: [auditorId], references: [id], onDelete: Cascade)
  
  title       String   // e.g., "Certificado ISO 9001 Lead Auditor"
  description String?  
  filePath    String   // Path to PDF file
  fileSize    Int?
  mimeType    String   @default("application/pdf")
  
  // Document metadata
  issueDate   DateTime? @db.Timestamptz
  expiryDate  DateTime? @db.Timestamptz
  issuer      String?  // Organization that issued the certificate
  
  // Soft delete
  deletedAt   DateTime? @db.Timestamptz
  
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz
  
  @@index([tenantId])
  @@index([auditorId])
  @@map("auditor_documents")
}

// Many-to-many: Audit <-> Auditor (team members)
model AuditAuditor {
  id        String @id @default(uuid()) @db.Uuid
  auditId   String @db.Uuid
  auditorId String @db.Uuid
  role      String?
  
  @@unique([auditId, auditorId])
  @@index([auditId])
  @@index([auditorId])
  @@map("audit_auditors")
}

// Checklist Template (reusable)
model AuditTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  
  name        String
  description String?
  normativeStandard IsoStandard
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  
  // Metadata
  createdById String   @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz
  deletedAt   DateTime? @db.Timestamptz
  
  @@unique([tenantId, name, version])
  @@index([tenantId])
  @@map("audit_templates")
}

model AuditTemplateItem {
  id              String   @id @default(uuid()) @db.Uuid
  templateId      String   @db.Uuid
  
  clause          String
  requirement     String
  whatToCheck     String
  guidance        String?
  weight          Decimal  @default(1) @db.Decimal(5, 2)
  order           Int      @default(0)
  
  @@index([templateId])
  @@map("audit_template_items")
}

// Checklist Items (instances from template)
model AuditChecklistItem {
  id              String   @id @default(uuid()) @db.Uuid
  auditId         String   @db.Uuid
  
  templateItemId  String?  @db.Uuid
  
  clause          String
  requirement     String
  whatToCheck     String
  weight          Decimal  @default(1) @db.Decimal(5, 2)
  order           Int      @default(0)
  
  // Response
  response        ChecklistResponseStatus?
  comment         String?
  evidence        String?  // URL or file path
  
  // AI suggestions
  aiSuggestedFinding Boolean @default(false)
  aiSuggestion    String?
  
  @@index([auditId])
  @@map("audit_checklist_items")
}

// Findings (Hallazgos)
model AuditFinding {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  auditId         String   @db.Uuid
  
  // Identification
  code            String
  type            FindingType
  severity        AuditFindingSeverity
  status          FindingStatus @default(OPEN)
  
  // Description
  description     String
  evidence        String?  // URL or file path
  clause          String   // Norm clause reference
  requirement     String   // Specific requirement
  
  // Location
  area            String
  process         String?
  
  // Assignment
  responsibleId   String   @db.Uuid
  detectedAt      DateTime @default(now()) @db.Timestamptz
  
  // Integration with other modules (solo IDs, no relaciones)
  ncrId           String?  @db.Uuid
  riskId          String?  @db.Uuid
  indicatorId     String?  @db.Uuid
  
  // Recurrence tracking
  isRecurrence    Boolean  @default(false)
  previousFindingId String?  @db.Uuid
  recurrenceCount   Int      @default(0)
  
  // AI analysis
  aiSuggestedActions String?
  aiImpactLevel   String?  // HIGH, MEDIUM, LOW
  
  // Metadata
  createdById     String   @db.Uuid
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz
  deletedAt       DateTime? @db.Timestamptz
  
  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([auditId])
  @@index([status])
  @@index([responsibleId])
  @@map("audit_findings")
}

// Corrective Actions from Findings
model AuditFindingAction {
  id              String   @id @default(uuid()) @db.Uuid
  findingId       String   @db.Uuid
  
  // Action details
  description     String   // What will be done
  rootCause       String?  // Root cause analysis (5 Whys, Ishikawa)
  type            String   // CORRECTIVE, PREVENTIVE, IMPROVEMENT
  
  // Assignment
  responsibleId   String   @db.Uuid
  
  // Planning
  plannedDate     DateTime @db.Timestamptz
  completedDate   DateTime? @db.Timestamptz
  
  // Status
  status          ActionStatus @default(PENDING)
  
  // Effectiveness validation
  isEffective     Boolean?
  validatedById   String?  @db.Uuid
  validatedAt     DateTime? @db.Timestamptz
  validationNotes String?
  
  // Evidence
  evidence        String?  // URL or file path
  
  // AI suggestions
  aiSuggested     Boolean  @default(false)
  aiRationale     String?
  
  // Metadata
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz
  deletedAt       DateTime? @db.Timestamptz
  
  @@index([findingId])
  @@index([responsibleId])
  @@index([status])
  @@map("audit_finding_actions")
}

// Audit Report
model AuditReport {
  id              String   @id @default(uuid()) @db.Uuid
  auditId         String   @db.Uuid @unique
  
  // Report content
  executiveSummary String
  objective       String
  scope           String
  processesAudited String[]
  
  // Results
  overallScore    Decimal? @db.Decimal(5, 2) // % compliance
  totalItems      Int      @default(0)
  compliantItems  Int      @default(0)
  nonCompliantItems Int    @default(0)
  
  // Findings summary
  totalFindings   Int      @default(0)
  openFindings    Int      @default(0)
  closedFindings  Int      @default(0)
  
  // Conclusion
  conclusion      String
  recommendations String?
  
  // Signatures
  auditorSignedAt DateTime? @db.Timestamptz
  auditorSignature String?  // Digital signature or name
  responsibleSignedAt DateTime? @db.Timestamptz
  responsibleSignature String?
  
  // Export files
  pdfUrl          String?
  wordUrl         String?
  
  // Metadata
  generatedAt     DateTime @default(now()) @db.Timestamptz
  generatedById   String   @db.Uuid
  updatedAt       DateTime @updatedAt @db.Timestamptz
  deletedAt       DateTime? @db.Timestamptz
  
  @@map("audit_reports")
}

// Management Review (Informes para la Dirección)
model ManagementReview {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  title        String
  summary      String?  @db.Text
  periodStart  DateTime @db.Timestamptz
  periodEnd    DateTime @db.Timestamptz
  standards    IsoStandard[]
  status       ManagementReviewStatus @default(DRAFT)
  generatedAt  DateTime @default(now()) @db.Timestamptz
  generatedById String @db.Uuid
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz
  deletedAt    DateTime? @db.Timestamptz

  sections ManagementReviewSection[]

  @@index([tenantId])
  @@index([tenantId, title])
  @@index([status])
  @@index([periodStart])
  @@index([periodEnd])
  @@map("management_reviews")
}

model ManagementReviewSection {
  id         String   @id @default(uuid()) @db.Uuid
  reportId   String   @db.Uuid
  key        String   // e.g., 'audit_results', 'nonconformities', 'kpi_performance'
  title      String
  systemData Json?    // Auto-generated data from the system
  freeText   String?  @db.Text // Manual text input
  outputs    String?  @db.Text // Output for each input
  decisions  Json?    // Decisions, actions, responsible, dates
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz

  report ManagementReview @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, key])
  @@index([reportId])
  @@map("management_review_sections")
}

enum ManagementReviewStatus {
  DRAFT
  FINAL
}

// ═══════════════════════════════════════════════════════════════
// Sistema de Licencias y Facturación
// ═══════════════════════════════════════════════════════════════

// Setup Inicial - Pago único de USD 200 para activar el sistema
model TenantSetup {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  amount     Float   @default(200.00)
  currency   String  @default("USD")
  status     SetupStatus @default(PENDING)
  
  // Fechas
  requestedAt DateTime  @default(now()) @db.Timestamptz
  paidAt      DateTime? @db.Timestamptz
  
  // Referencia de pago (Stripe/PayPal/etc)
  provider    String?
  providerRef String?
  
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@index([tenantId])
  @@map("tenant_setups")
}

// Historial de Pagos de Suscripción
model Payment {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  subscriptionId String          @db.Uuid
  subscription   TenantSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  // Relación con Plan (faltaba)
  planId String @db.Uuid
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  // Detalles del pago
  amount        Float
  currency      String   @default("USD")
  period        String   // "monthly" | "annual"
  planTier      PlanTier
  
  // Estados
  status        PaymentStatus @default(PENDING)
  
  // Fechas
  periodStart   DateTime? @db.Timestamptz
  periodEnd     DateTime? @db.Timestamptz
  paidAt        DateTime? @db.Timestamptz
  
  // Referencia de pago externo
  provider      String?
  providerRef   String?
  
  // Metadata
  receiptUrl    String?
  notes         String?
  
  // Relaciones inversas
  invoice       Invoice?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@index([tenantId])
  @@index([subscriptionId])
  @@index([planId])
  @@index([status])
  @@map("payments")
}

// Factura asociada a un pago
model Invoice {
  id          String   @id @default(uuid()) @db.Uuid
  paymentId   String   @db.Uuid @unique
  payment     Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Datos de la factura
  invoiceNumber String   @unique // Número de factura (F-001, F-002, etc.)
  invoiceDate   DateTime @default(now()) @db.Timestamptz
  dueDate       DateTime? @db.Timestamptz
  
  // Montos
  subtotal    Float
  taxAmount   Float    @default(0)
  total       Float
  currency    String   @default("USD")
  
  // Datos fiscales del cliente
  customerName    String
  customerTaxId   String?
  customerAddress String?
  
  // Archivo PDF de la factura
  pdfPath     String?
  pdfUrl      String?
  
  // Estado
  status      String   @default("ISSUED") // ISSUED, SENT, PAID, CANCELLED
  
  // Metadata
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz
  createdById String?  @db.Uuid
  createdBy   PlatformUser? @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  
  @@index([tenantId])
  @@index([paymentId])
  @@index([status])
  @@map("invoices")
}

// Preferencia de pago (para MercadoPago checkout)
model PaymentPreference {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  userId    String?  @db.Uuid
  
  // Plan seleccionado
  planTier  String
  period    String   @default("monthly") // monthly, annual
  amount    Float
  currency  String   @default("USD")
  
  // MercadoPago
  mpPreferenceId String? @unique
  mpInitPoint    String?
  
  // Estado
  status    String   @default("PENDING") // PENDING, COMPLETED, CANCELLED, EXPIRED
  
  // Metadatos del pago
  paymentData    Json?    // Datos del pago cuando se completa
  
  createdAt      DateTime @default(now()) @db.Timestamptz
  updatedAt      DateTime @updatedAt @db.Timestamptz
  expiresAt      DateTime? @db.Timestamptz
  
  @@index([tenantId])
  @@index([status])
  @@index([mpPreferenceId])
  @@map("payment_preferences")
}

// Notificaciones para administradores (pagos, alertas)
model AdminNotification {
  id          String   @id @default(uuid()) @db.Uuid
  
  type        String   // PAYMENT_RECEIVED, INVOICE_REQUIRED, SYSTEM_ALERT, etc.
  title       String
  message     String
  
  // Datos adicionales en JSON
  data        Json?
  
  // Estado
  isRead      Boolean  @default(false)
  readAt      DateTime? @db.Timestamptz
  
  // Link para acción (opcional)
  actionLink  String?
  actionLabel String?
  
  createdAt   DateTime @default(now()) @db.Timestamptz
  
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@map("admin_notifications")
}

// Configuración de MercadoPago
model MercadoPagoConfig {
  id          String   @id @default(uuid()) @db.Uuid
  
  accessToken String
  publicKey   String?
  webhookSecret String?
  
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz
  
  @@map("mercadopago_config")
}
model LicenseAccessAttempt {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId   String       @db.Uuid
  user     PlatformUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  module   String   // Nombre del módulo intentado
  path     String   // Ruta completa
  count    Int      @default(1)
  
  lastAttemptAt DateTime @default(now()) @db.Timestamptz

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@unique([tenantId, userId, module])
  @@index([tenantId])
  @@index([userId])
  @@map("license_access_attempts")
}

// Notificaciones de licencia (vencimientos, período de gracia, etc.)
model LicenseNotification {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId   String?       @db.Uuid
  user     PlatformUser? @relation(fields: [userId], references: [id], onDelete: Cascade)

  type     LicenseNotificationType
  title    String
  message  String
  
  // Mostrar hasta
  expiresAt DateTime? @db.Timestamptz
  
  // Estado
  isRead    Boolean  @default(false)
  readAt    DateTime? @db.Timestamptz
  
  // Acción tomada
  actionTaken String? // "UPGRADE", "DISMISS", etc.

  createdAt DateTime @default(now()) @db.Timestamptz

  @@index([tenantId])
  @@index([userId])
  @@index([type])
  @@map("license_notifications")
}

// Enums para el sistema de licencias
enum SetupStatus {
  PENDING
  PAID
  WAIVED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  DISPUTED
}

enum LicenseNotificationType {
