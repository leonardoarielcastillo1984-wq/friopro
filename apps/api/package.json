{
  "name": "@sgi360/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --import tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed:plans": "node --import tsx src/scripts/seedPlans.ts",
    "seed:users": "node --import tsx src/scripts/seedUsers.ts",
    "seed:demo": "node --import tsx src/scripts/seedDemoData.ts",
    "seed:2fa": "node --import tsx src/scripts/seed2FA.ts",
    "seed:all": "npm run seed:plans && npm run seed:users && npm run seed:demo",
    "seed:complete": "npm run seed:all && npm run seed:2fa",
    "prisma:reset": "prisma migrate reset --force",
    "setup": "npm run prisma:generate && npm run prisma:reset && npm run seed:complete",
    "test": "node --test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1008.0",
    "@aws-sdk/lib-storage": "^3.1008.0",
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@prisma/client": "^5.22.0",
    "argon2": "^0.40.3",
    "bullmq": "^5.12.6",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "fastify": "^5.8.2",
    "fastify-plugin": "^4.5.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "nodemailer": "^8.0.2",
    "openai": "^4.73.0",
    "pdf-parse": "^1.1.1",
    "qrcode": "^1.5.3",
    "resend": "^6.9.3",
    "speakeasy": "^2.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "prisma": {
    "seed": "node --import tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "prisma": "^5.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
