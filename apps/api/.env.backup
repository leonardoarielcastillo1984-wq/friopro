# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://sgi:sgi@localhost:5432/sgi?schema=public
DATABASE_URL_AUDITOR=postgresql://sgi_auditor:sgi_auditor@localhost:5432/sgi?schema=public

# Auth
JWT_SECRET=change-me-dev
JWT_ISSUER=sgi360
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Storage
# Options: local | s3
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads
MAX_PDF_SIZE_MB=50
# S3 (when STORAGE_BACKEND=s3)
# S3_BUCKET=sgi360-uploads
# S3_ENDPOINT=             # optional: for MinIO / R2 / DigitalOcean Spaces
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# CORS
CORS_ORIGIN=http://localhost:3000

# Email
# Options: console | resend | smtp
EMAIL_PROVIDER=console
EMAIL_FROM=SGI 360 <noreply@sgi360.app>
# Resend (when EMAIL_PROVIDER=resend)
# RESEND_API_KEY=re_xxxxx
# SMTP (when EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false

# LLM Provider (Motor de IA Auditora)
# Options: anthropic | openai | ollama
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4-turbo
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434/v1
AUDIT_MAX_TOKENS=4000
HOST=127.0.0.1
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
HOST=127.0.0.1
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
