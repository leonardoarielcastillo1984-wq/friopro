#!/bin/bash

# SGI 360 Launcher - Interfaz Gráfica
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

# Función para mostrar diálogo con opciones
show_dialog() {
    osascript << EOF
tell application "System Events"
    activate
    set theResult to button returned of (display dialog "SGI 360 - Sistema de Gestión Integrado" & return & return & "¿Qué querés hacer?" buttons {"Iniciar Todo", "Detener Todo", "Cancelar"} default button "Iniciar Todo" with icon note with title "SGI 360")
    return theResult
end tell
EOF
}

# Función para mostrar progreso
show_progress() {
    local message="$1"
    osascript << EOF
tell application "System Events"
    activate
    display notification "$message" with title "SGI 360" subtitle "Progreso"
end tell
EOF
}

# Función para mostrar resultado
show_result() {
    local title="$1"
    local message="$2"
    local success="$3"
    
    if [ "$success" = "true" ]; then
        osascript << EOF
tell application "System Events"
    activate
    display dialog "$message" buttons {"OK"} default button "OK" with icon stop with title "$title"
end tell
EOF
    else
        osascript << EOF
tell application "System Events"
    activate
    display dialog "$message" buttons {"OK"} default button "OK" with icon stop with title "$title"
end tell
EOF
    fi
}

# Función para iniciar todo
start_all() {
    show_progress "🚀 Iniciando SGI 360..."
    
    cd "$SCRIPT_DIR"
    
    # Ejecutar auto-start.sh y capturar output
    if ./auto-start.sh > /tmp/sgi360-start.log 2>&1; then
        show_progress "✅ SGI 360 iniciado correctamente"
        sleep 2
        
        # Abrir navegador
        open http://localhost:3000
        
        show_result "✅ Éxito" "SGI 360 está corriendo en http://localhost:3000\n\nLogin: admin@sgi360.com / Admin123!\n\nLogs: /tmp/sgi360-start.log" "true"
    else
        show_result "❌ Error" "Hubo un error al iniciar SGI 360.\n\nRevisá los logs en: /tmp/sgi360-start.log\n\nAsegurate que Docker Desktop esté corriendo." "false"
    fi
}

# Función para detener todo
stop_all() {
    show_progress "🛑 Deteniendo SGI 360..."
    
    cd "$SCRIPT_DIR"
    
    if ./auto-stop.sh > /tmp/sgi360-stop.log 2>&1; then
        show_progress "✅ SGI 360 detenido"
        sleep 1
        show_result "✅ Detenido" "SGI 360 se ha detenido correctamente.\n\nLogs: /tmp/sgi360-stop.log" "true"
    else
        show_result "❌ Error" "Hubo un error al detener SGI 360.\n\nRevisá los logs en: /tmp/sgi360-stop.log" "false"
    fi
}

# Loop principal - ejecutar solo una vez
choice=$(show_dialog)

case "$choice" in
    "Iniciar Todo")
        start_all
        exit 0
        ;;
    "Detener Todo")
        stop_all
        exit 0
        ;;
    "Cancelar"|"")
        exit 0
        ;;
esac
